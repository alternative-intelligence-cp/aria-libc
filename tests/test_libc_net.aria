// test_libc_net.aria — Tests for aria-libc Networking wrappers
//
// Compile:
//   ariac test_libc_net.aria -o test_libc_net -L../shim -laria_libc_net
//
// Run:
//   LD_LIBRARY_PATH=../shim ./test_libc_net

extern "aria_libc_net" {
    func:aria_libc_net_errno = int64();
    func:aria_libc_net_strerror = string(int64:errnum);

    // Constants
    func:aria_libc_net_AF_INET = int64();
    func:aria_libc_net_AF_INET6 = int64();
    func:aria_libc_net_AF_UNIX = int64();
    func:aria_libc_net_AF_UNSPEC = int64();
    func:aria_libc_net_SOCK_STREAM = int64();
    func:aria_libc_net_SOCK_DGRAM = int64();
    func:aria_libc_net_SOCK_RAW = int64();
    func:aria_libc_net_IPPROTO_TCP = int64();
    func:aria_libc_net_IPPROTO_UDP = int64();
    func:aria_libc_net_SOL_SOCKET = int64();
    func:aria_libc_net_SO_REUSEADDR = int64();
    func:aria_libc_net_SO_REUSEPORT = int64();
    func:aria_libc_net_SO_KEEPALIVE = int64();
    func:aria_libc_net_SO_RCVBUF = int64();
    func:aria_libc_net_SO_SNDBUF = int64();
    func:aria_libc_net_SO_ERROR = int64();
    func:aria_libc_net_TCP_NODELAY = int64();
    func:aria_libc_net_SHUT_RD = int64();
    func:aria_libc_net_SHUT_WR = int64();
    func:aria_libc_net_SHUT_RDWR = int64();
    func:aria_libc_net_POLLIN = int64();
    func:aria_libc_net_POLLOUT = int64();
    func:aria_libc_net_POLLERR = int64();
    func:aria_libc_net_POLLHUP = int64();

    // Core operations
    func:aria_libc_net_socket = int64(int64:domain, int64:type, int64:protocol);
    func:aria_libc_net_close = int64(int64:fd);
    func:aria_libc_net_shutdown = int64(int64:fd, int64:how);

    // Bind / Listen / Accept
    func:aria_libc_net_bind_ipv4 = int64(int64:fd, string:addr, int64:port);
    func:aria_libc_net_listen = int64(int64:fd, int64:backlog);
    func:aria_libc_net_accept = int64(int64:fd);

    // Connect
    func:aria_libc_net_connect_ipv4 = int64(int64:fd, string:addr, int64:port);

    // Send / Recv
    func:aria_libc_net_send_string = int64(int64:fd, string:data);
    func:aria_libc_net_recv_string = string(int64:fd, int64:max_len);
    func:aria_libc_net_recv_bytes = int64(int64:fd, int64:max_len);

    // UDP
    func:aria_libc_net_sendto_ipv4 = int64(int64:fd, string:data, string:addr, int64:port);
    func:aria_libc_net_recvfrom_ipv4 = string(int64:fd, int64:max_len);

    // Socket options
    func:aria_libc_net_setsockopt_int = int64(int64:fd, int64:level, int64:optname, int64:val);
    func:aria_libc_net_getsockopt_int = int64(int64:fd, int64:level, int64:optname);

    // Non-blocking
    func:aria_libc_net_set_nonblocking = int64(int64:fd, int64:enabled);
    func:aria_libc_net_is_nonblocking = int64(int64:fd);

    // Poll
    func:aria_libc_net_poll_read = int64(int64:fd, int64:timeout_ms);
    func:aria_libc_net_poll_write = int64(int64:fd, int64:timeout_ms);

    // Address resolution
    func:aria_libc_net_resolve_ipv4 = string(string:hostname);
    func:aria_libc_net_resolve = string(string:hostname);

    // Peer/local info
    func:aria_libc_net_peer_addr = string(int64:fd);
    func:aria_libc_net_peer_port = int64(int64:fd);
    func:aria_libc_net_local_addr = string(int64:fd);
    func:aria_libc_net_local_port = int64(int64:fd);

    // Convenience
    func:aria_libc_net_tcp_connect = int64(string:host, int64:port);
    func:aria_libc_net_tcp_listen = int64(string:addr, int64:port, int64:backlog);

    // Hostname/IP utilities
    func:aria_libc_net_gethostname = string();
    func:aria_libc_net_inet_aton = int64(string:addr);
    func:aria_libc_net_inet_ntoa = string(int64:ip);
    func:aria_libc_net_htons = int64(int64:val);
    func:aria_libc_net_ntohs = int64(int64:val);
    func:aria_libc_net_htonl = int64(int64:val);
    func:aria_libc_net_ntohl = int64(int64:val);
}

int64:pass_count = 0i64;
int64:fail_count = 0i64;

func:assert_eq = NIL(int64:actual, int64:expected, string:msg) {
    if (actual == expected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected: " + string_from_int(expected)));
        drop(print("    actual:   " + string_from_int(actual)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_neq = NIL(int64:actual, int64:unexpected, string:msg) {
    if (actual != unexpected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    should not be: " + string_from_int(unexpected)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_gt = NIL(int64:actual, int64:threshold, string:msg) {
    if (actual > threshold) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected > " + string_from_int(threshold)));
        drop(print("    actual:    " + string_from_int(actual)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_gte = NIL(int64:actual, int64:threshold, string:msg) {
    if (actual >= threshold) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected >= " + string_from_int(threshold)));
        drop(print("    actual:     " + string_from_int(actual)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_str_eq = NIL(string:actual, string:expected, string:msg) {
    if (actual == expected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected: " + expected));
        drop(print("    actual:   " + actual));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_str_neq = NIL(string:actual, string:unexpected, string:msg) {
    if (actual != unexpected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    should not be: " + unexpected));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Constants
// ══════════════════════════════════════════════════════════════════════

func:test_constants = NIL() {
    drop(println("=== Constants ==="));

    // Address families — must be positive
    int64:af4 = aria_libc_net_AF_INET();
    drop(assert_gt(af4, 0i64, "AF_INET > 0"));

    int64:af6 = aria_libc_net_AF_INET6();
    drop(assert_gt(af6, 0i64, "AF_INET6 > 0"));

    // Socket types
    int64:st = aria_libc_net_SOCK_STREAM();
    drop(assert_gt(st, 0i64, "SOCK_STREAM > 0"));

    int64:dg = aria_libc_net_SOCK_DGRAM();
    drop(assert_gt(dg, 0i64, "SOCK_DGRAM > 0"));

    // Protocols
    int64:tcp = aria_libc_net_IPPROTO_TCP();
    drop(assert_gt(tcp, 0i64, "IPPROTO_TCP > 0"));

    int64:udp = aria_libc_net_IPPROTO_UDP();
    drop(assert_gt(udp, 0i64, "IPPROTO_UDP > 0"));

    // Socket options
    int64:sol = aria_libc_net_SOL_SOCKET();
    drop(assert_gt(sol, 0i64, "SOL_SOCKET > 0"));

    int64:reuse = aria_libc_net_SO_REUSEADDR();
    drop(assert_gt(reuse, 0i64, "SO_REUSEADDR > 0"));

    int64:nodelay = aria_libc_net_TCP_NODELAY();
    drop(assert_gt(nodelay, 0i64, "TCP_NODELAY > 0"));

    // Poll flags
    int64:pollin = aria_libc_net_POLLIN();
    drop(assert_gt(pollin, 0i64, "POLLIN > 0"));

    int64:pollout = aria_libc_net_POLLOUT();
    drop(assert_gt(pollout, 0i64, "POLLOUT > 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Socket creation and close
// ══════════════════════════════════════════════════════════════════════

func:test_socket_create_close = NIL() {
    drop(println("=== Socket Create / Close ==="));

    int64:af = aria_libc_net_AF_INET();
    int64:st = aria_libc_net_SOCK_STREAM();

    // Create a TCP socket
    int64:fd = aria_libc_net_socket(af, st, 0i64);
    drop(assert_gte(fd, 0i64, "socket() returns valid fd"));

    // Close it
    int64:rc = aria_libc_net_close(fd);
    drop(assert_eq(rc, 0i64, "close() returns 0"));

    // Create a UDP socket
    int64:dg = aria_libc_net_SOCK_DGRAM();
    int64:ufd = aria_libc_net_socket(af, dg, 0i64);
    drop(assert_gte(ufd, 0i64, "socket(DGRAM) returns valid fd"));
    int64:rc2 = aria_libc_net_close(ufd);
    drop(assert_eq(rc2, 0i64, "close(udp) returns 0"));

    // Close invalid fd returns -1
    int64:bad = aria_libc_net_close(9999i64);
    drop(assert_eq(bad, 0i64 - 1i64, "close(9999) returns -1"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Socket options
// ══════════════════════════════════════════════════════════════════════

func:test_socket_options = NIL() {
    drop(println("=== Socket Options ==="));

    int64:af = aria_libc_net_AF_INET();
    int64:st = aria_libc_net_SOCK_STREAM();
    int64:fd = aria_libc_net_socket(af, st, 0i64);

    // Set SO_REUSEADDR
    int64:sol = aria_libc_net_SOL_SOCKET();
    int64:reuse = aria_libc_net_SO_REUSEADDR();
    int64:rc = aria_libc_net_setsockopt_int(fd, sol, reuse, 1i64);
    drop(assert_eq(rc, 0i64, "setsockopt(SO_REUSEADDR, 1) returns 0"));

    // Get SO_REUSEADDR
    int64:val = aria_libc_net_getsockopt_int(fd, sol, reuse);
    drop(assert_eq(val, 1i64, "getsockopt(SO_REUSEADDR) returns 1"));

    // Set TCP_NODELAY
    int64:tcp_proto = aria_libc_net_IPPROTO_TCP();
    int64:nodelay = aria_libc_net_TCP_NODELAY();
    int64:rc2 = aria_libc_net_setsockopt_int(fd, tcp_proto, nodelay, 1i64);
    drop(assert_eq(rc2, 0i64, "setsockopt(TCP_NODELAY, 1) returns 0"));

    int64:val2 = aria_libc_net_getsockopt_int(fd, tcp_proto, nodelay);
    drop(assert_eq(val2, 1i64, "getsockopt(TCP_NODELAY) returns 1"));

    int64:rc3 = aria_libc_net_close(fd);
    drop(assert_eq(rc3, 0i64, "close after sockopt returns 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Non-blocking mode
// ══════════════════════════════════════════════════════════════════════

func:test_nonblocking = NIL() {
    drop(println("=== Non-blocking ==="));

    int64:af = aria_libc_net_AF_INET();
    int64:st = aria_libc_net_SOCK_STREAM();
    int64:fd = aria_libc_net_socket(af, st, 0i64);

    // Default: blocking
    int64:nb = aria_libc_net_is_nonblocking(fd);
    drop(assert_eq(nb, 0i64, "default is blocking"));

    // Set non-blocking
    int64:rc = aria_libc_net_set_nonblocking(fd, 1i64);
    drop(assert_eq(rc, 0i64, "set_nonblocking(1) returns 0"));

    int64:nb2 = aria_libc_net_is_nonblocking(fd);
    drop(assert_eq(nb2, 1i64, "is_nonblocking returns 1"));

    // Revert to blocking
    int64:rc2 = aria_libc_net_set_nonblocking(fd, 0i64);
    drop(assert_eq(rc2, 0i64, "set_nonblocking(0) returns 0"));

    int64:nb3 = aria_libc_net_is_nonblocking(fd);
    drop(assert_eq(nb3, 0i64, "is_nonblocking back to 0"));

    int64:rc3 = aria_libc_net_close(fd);
    drop(assert_eq(rc3, 0i64, "close after nonblock returns 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Bind and listen
// ══════════════════════════════════════════════════════════════════════

func:test_bind_listen = NIL() {
    drop(println("=== Bind / Listen ==="));

    int64:af = aria_libc_net_AF_INET();
    int64:st = aria_libc_net_SOCK_STREAM();
    int64:fd = aria_libc_net_socket(af, st, 0i64);

    // Set SO_REUSEADDR
    int64:sol = aria_libc_net_SOL_SOCKET();
    int64:reuse = aria_libc_net_SO_REUSEADDR();
    drop(aria_libc_net_setsockopt_int(fd, sol, reuse, 1i64));

    // Bind to loopback, port 0 (OS picks ephemeral port)
    int64:rc = aria_libc_net_bind_ipv4(fd, "127.0.0.1", 0i64);
    drop(assert_eq(rc, 0i64, "bind(127.0.0.1:0) returns 0"));

    // Listen
    int64:rc2 = aria_libc_net_listen(fd, 5i64);
    drop(assert_eq(rc2, 0i64, "listen(5) returns 0"));

    // Check local port was assigned
    int64:port = aria_libc_net_local_port(fd);
    drop(assert_gt(port, 0i64, "local_port > 0 (ephemeral assigned)"));

    // Check local addr
    string:addr = aria_libc_net_local_addr(fd);
    drop(assert_str_eq(addr, "127.0.0.1", "local_addr is 127.0.0.1"));

    int64:rc3 = aria_libc_net_close(fd);
    drop(assert_eq(rc3, 0i64, "close server socket returns 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: TCP connect/accept/send/recv (loopback)
// ══════════════════════════════════════════════════════════════════════

func:test_tcp_loopback = NIL() {
    drop(println("=== TCP Loopback ==="));

    // Create server socket
    int64:sfd = aria_libc_net_tcp_listen("127.0.0.1", 0i64, 5i64);
    drop(assert_gte(sfd, 0i64, "tcp_listen returns valid fd"));

    // Get the port the OS assigned
    int64:port = aria_libc_net_local_port(sfd);
    drop(assert_gt(port, 0i64, "server port > 0"));

    // Create client socket and connect
    int64:af = aria_libc_net_AF_INET();
    int64:st = aria_libc_net_SOCK_STREAM();
    int64:cfd = aria_libc_net_socket(af, st, 0i64);
    int64:rc = aria_libc_net_connect_ipv4(cfd, "127.0.0.1", port);
    drop(assert_eq(rc, 0i64, "connect to loopback returns 0"));

    // Accept client on server side
    int64:afd = aria_libc_net_accept(sfd);
    drop(assert_gte(afd, 0i64, "accept returns valid fd"));

    // Send from client
    int64:sent = aria_libc_net_send_string(cfd, "hello from aria");
    drop(assert_eq(sent, 15i64, "send 15 bytes"));

    // Recv on server side
    string:data = aria_libc_net_recv_string(afd, 1024i64);
    drop(assert_str_eq(data, "hello from aria", "recv matches sent data"));

    // Send from server back to client
    int64:sent2 = aria_libc_net_send_string(afd, "pong");
    drop(assert_eq(sent2, 4i64, "server sends 4 bytes"));

    // Recv on client side
    string:reply = aria_libc_net_recv_string(cfd, 1024i64);
    drop(assert_str_eq(reply, "pong", "client receives pong"));

    // Check peer info from accepted fd
    string:peer = aria_libc_net_peer_addr(afd);
    drop(assert_str_eq(peer, "127.0.0.1", "peer_addr is 127.0.0.1"));

    int64:pport = aria_libc_net_peer_port(afd);
    drop(assert_gt(pport, 0i64, "peer_port > 0"));

    // Shutdown and close
    int64:shut = aria_libc_net_SHUT_RDWR();
    drop(aria_libc_net_shutdown(cfd, shut));
    drop(aria_libc_net_close(cfd));
    drop(aria_libc_net_close(afd));
    drop(aria_libc_net_close(sfd));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: UDP loopback
// ══════════════════════════════════════════════════════════════════════

func:test_udp_loopback = NIL() {
    drop(println("=== UDP Loopback ==="));

    int64:af = aria_libc_net_AF_INET();
    int64:dg = aria_libc_net_SOCK_DGRAM();

    // Create receiver socket
    int64:rfd = aria_libc_net_socket(af, dg, 0i64);
    drop(assert_gte(rfd, 0i64, "udp recv socket created"));

    int64:rc = aria_libc_net_bind_ipv4(rfd, "127.0.0.1", 0i64);
    drop(assert_eq(rc, 0i64, "udp bind returns 0"));

    int64:rport = aria_libc_net_local_port(rfd);
    drop(assert_gt(rport, 0i64, "udp recv port > 0"));

    // Create sender socket
    int64:sfd = aria_libc_net_socket(af, dg, 0i64);
    drop(assert_gte(sfd, 0i64, "udp send socket created"));

    // Send data
    int64:sent = aria_libc_net_sendto_ipv4(sfd, "udp hello", "127.0.0.1", rport);
    drop(assert_eq(sent, 9i64, "sendto sends 9 bytes"));

    // Receive data
    string:data = aria_libc_net_recvfrom_ipv4(rfd, 1024i64);
    drop(assert_str_eq(data, "udp hello", "recvfrom matches sent data"));

    drop(aria_libc_net_close(sfd));
    drop(aria_libc_net_close(rfd));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Address resolution
// ══════════════════════════════════════════════════════════════════════

func:test_resolve = NIL() {
    drop(println("=== Address Resolution ==="));

    // Resolve localhost — should be 127.0.0.1
    string:ip = aria_libc_net_resolve_ipv4("localhost");
    drop(assert_str_eq(ip, "127.0.0.1", "resolve_ipv4(localhost) = 127.0.0.1"));

    // Generic resolve localhost
    string:ip2 = aria_libc_net_resolve("localhost");
    // Could be 127.0.0.1 or ::1 depending on system, just check non-empty
    int64:len = string_length(ip2);
    drop(assert_gt(len, 0i64, "resolve(localhost) returns non-empty string"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Hostname / IP utilities
// ══════════════════════════════════════════════════════════════════════

func:test_ip_utils = NIL() {
    drop(println("=== IP Utilities ==="));

    // gethostname — should return something non-empty
    string:hostname = aria_libc_net_gethostname();
    int64:hlen = string_length(hostname);
    drop(assert_gt(hlen, 0i64, "gethostname returns non-empty"));

    // inet_aton: 127.0.0.1 = 0x7F000001 = 2130706433
    int64:ip = aria_libc_net_inet_aton("127.0.0.1");
    drop(assert_eq(ip, 2130706433i64, "inet_aton(127.0.0.1) = 2130706433"));

    // inet_ntoa: 2130706433 -> 127.0.0.1
    string:addr = aria_libc_net_inet_ntoa(2130706433i64);
    drop(assert_str_eq(addr, "127.0.0.1", "inet_ntoa(2130706433) = 127.0.0.1"));

    // htons/ntohs roundtrip
    int64:n = aria_libc_net_htons(80i64);
    int64:h = aria_libc_net_ntohs(n);
    drop(assert_eq(h, 80i64, "htons/ntohs roundtrip = 80"));

    // htonl/ntohl roundtrip
    int64:n2 = aria_libc_net_htonl(12345i64);
    int64:h2 = aria_libc_net_ntohl(n2);
    drop(assert_eq(h2, 12345i64, "htonl/ntohl roundtrip = 12345"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Poll (timeout on empty socket)
// ══════════════════════════════════════════════════════════════════════

func:test_poll = NIL() {
    drop(println("=== Poll ==="));

    // Create a TCP socket (not connected) and poll for read — should timeout
    int64:af = aria_libc_net_AF_INET();
    int64:st = aria_libc_net_SOCK_STREAM();
    int64:fd = aria_libc_net_socket(af, st, 0i64);

    // poll_read with 10ms timeout — returns 0 (timeout) or POLLHUP (16) on Linux
    int64:events = aria_libc_net_poll_read(fd, 10i64);
    drop(assert_gte(events, 0i64, "poll_read on unconnected socket >= 0 (no error)"));

    // poll_write with 10ms — writable since buffer is empty on unconnected
    // (behavior varies; just check it doesn't error)
    int64:wevt = aria_libc_net_poll_write(fd, 10i64);
    drop(assert_gte(wevt, 0i64, "poll_write >= 0 (no error)"));

    drop(aria_libc_net_close(fd));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Error reporting
// ══════════════════════════════════════════════════════════════════════

func:test_errno = NIL() {
    drop(println("=== Error Reporting ==="));

    // Force an error by closing an invalid fd
    int64:rc = aria_libc_net_close(9998i64);
    drop(assert_eq(rc, 0i64 - 1i64, "close(9998) returns -1"));

    int64:err = aria_libc_net_errno();
    drop(assert_gt(err, 0i64, "errno > 0 after bad close"));

    string:msg = aria_libc_net_strerror(err);
    int64:mlen = string_length(msg);
    drop(assert_gt(mlen, 0i64, "strerror returns non-empty message"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: tcp_listen convenience function
// ══════════════════════════════════════════════════════════════════════

func:test_tcp_listen_convenience = NIL() {
    drop(println("=== TCP Listen Convenience ==="));

    // tcp_listen binds + listens in one call
    int64:fd = aria_libc_net_tcp_listen("127.0.0.1", 0i64, 10i64);
    drop(assert_gte(fd, 0i64, "tcp_listen returns valid fd"));

    int64:port = aria_libc_net_local_port(fd);
    drop(assert_gt(port, 0i64, "tcp_listen assigned port > 0"));

    string:addr = aria_libc_net_local_addr(fd);
    drop(assert_str_eq(addr, "127.0.0.1", "tcp_listen addr is 127.0.0.1"));

    drop(aria_libc_net_close(fd));

    pass(NIL);
};

