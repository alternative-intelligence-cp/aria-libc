    drop(assert_gt(aria_libc_posix_MAP_SHARED(), 0i64, "MAP_SHARED > 0"));
    drop(assert_gt(aria_libc_posix_MAP_PRIVATE(), 0i64, "MAP_PRIVATE > 0"));
    drop(assert_gt(aria_libc_posix_MAP_ANONYMOUS(), 0i64, "MAP_ANONYMOUS > 0"));
    drop(assert_gt(aria_libc_posix_MS_ASYNC(), 0i64, "MS_ASYNC > 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: mmap anonymous — byte read/write
// ══════════════════════════════════════════════════════════════════════

func:test_mmap_bytes = NIL() {
    drop(println("=== mmap Byte R/W ==="));

    int64:prot = aria_libc_posix_PROT_READ() + aria_libc_posix_PROT_WRITE();
    int64:flags = aria_libc_posix_MAP_PRIVATE() + aria_libc_posix_MAP_ANONYMOUS();

    // Map 4096 bytes anonymous
    int64:handle = aria_libc_posix_mmap(4096i64, prot, flags, 0i64 - 1i64, 0i64);
    drop(assert_gte(handle, 0i64, "mmap anonymous returns valid handle"));

    // Check length
    int64:mlen = aria_libc_posix_mmap_length(handle);
    drop(assert_eq(mlen, 4096i64, "mmap length = 4096"));

    // Write byte
    int64:wrc = aria_libc_posix_mmap_write_byte(handle, 0i64, 42i64);
    drop(assert_eq(wrc, 0i64, "write_byte returns 0"));

    int64:wrc2 = aria_libc_posix_mmap_write_byte(handle, 1i64, 255i64);
    drop(assert_eq(wrc2, 0i64, "write_byte(255) returns 0"));

    // Read byte
    int64:rb = aria_libc_posix_mmap_read_byte(handle, 0i64);
    drop(assert_eq(rb, 42i64, "read_byte(0) = 42"));

    int64:rb2 = aria_libc_posix_mmap_read_byte(handle, 1i64);
    drop(assert_eq(rb2, 255i64, "read_byte(1) = 255"));

    // Read unwritten byte (should be 0 — anonymous maps are zero-filled)
    int64:rb3 = aria_libc_posix_mmap_read_byte(handle, 100i64);
    drop(assert_eq(rb3, 0i64, "unwritten byte = 0"));

    // Unmap
    int64:urc = aria_libc_posix_munmap(handle);
    drop(assert_eq(urc, 0i64, "munmap returns 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: mmap int64 + string read/write
// ══════════════════════════════════════════════════════════════════════

func:test_mmap_data = NIL() {
    drop(println("=== mmap Int64 + String R/W ==="));

    int64:prot = aria_libc_posix_PROT_READ() + aria_libc_posix_PROT_WRITE();
    int64:flags = aria_libc_posix_MAP_PRIVATE() + aria_libc_posix_MAP_ANONYMOUS();

    int64:handle = aria_libc_posix_mmap(4096i64, prot, flags, 0i64 - 1i64, 0i64);
    drop(assert_gte(handle, 0i64, "mmap for data test"));

    // Write int64
    int64:wrc = aria_libc_posix_mmap_write_int64(handle, 0i64, 123456789i64);
    drop(assert_eq(wrc, 0i64, "write_int64 returns 0"));

    // Read int64
    int64:val = aria_libc_posix_mmap_read_int64(handle, 0i64);
    drop(assert_eq(val, 123456789i64, "read_int64 = 123456789"));

    // Write string at offset 64
    int64:slen = aria_libc_posix_mmap_from_string(handle, 64i64, "Hello mmap!");
    drop(assert_eq(slen, 11i64, "wrote 11 bytes of string"));

    // Read string back
    string:sdata = aria_libc_posix_mmap_to_string(handle, 64i64, 11i64);
    drop(assert_str_eq(sdata, "Hello mmap!", "string roundtrip matches"));

    // Cleanup
    int64:urc = aria_libc_posix_munmap(handle);
    drop(assert_eq(urc, 0i64, "munmap data region"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: mmap mprotect — change to read-only, verify we can still read
// ══════════════════════════════════════════════════════════════════════

func:test_mmap_protect = NIL() {
    drop(println("=== mmap Mprotect ==="));

    int64:prot_rw = aria_libc_posix_PROT_READ() + aria_libc_posix_PROT_WRITE();
    int64:flags = aria_libc_posix_MAP_PRIVATE() + aria_libc_posix_MAP_ANONYMOUS();

    int64:handle = aria_libc_posix_mmap(4096i64, prot_rw, flags, 0i64 - 1i64, 0i64);
    drop(assert_gte(handle, 0i64, "mmap for mprotect test"));

    // Write while writable
    int64:wrc = aria_libc_posix_mmap_write_byte(handle, 0i64, 77i64);
    drop(assert_eq(wrc, 0i64, "write while PROT_READ|PROT_WRITE"));

    // Change to read-only
    int64:prc = aria_libc_posix_mprotect(handle, aria_libc_posix_PROT_READ());
    drop(assert_eq(prc, 0i64, "mprotect to PROT_READ returns 0"));

    // Can still read
    int64:rb = aria_libc_posix_mmap_read_byte(handle, 0i64);
    drop(assert_eq(rb, 77i64, "read after mprotect(READ) = 77"));

    // Cleanup
    int64:urc = aria_libc_posix_munmap(handle);
    drop(assert_eq(urc, 0i64, "munmap after mprotect"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Error reporting
// ══════════════════════════════════════════════════════════════════════

func:test_error = NIL() {
    drop(println("=== Error Reporting ==="));

    // Bad munmap handle
    int64:rc = aria_libc_posix_munmap(99i64);
    drop(assert_eq(rc, 0i64 - 1i64, "munmap(99) returns -1"));

    int64:eno = aria_libc_posix_errno();
    drop(assert_gt(eno, 0i64, "errno > 0 after bad munmap"));

    string:msg = aria_libc_posix_strerror(eno);
    drop(assert_str_neq(msg, "", "strerror returns non-empty"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Kill (send signal to own process)
// ══════════════════════════════════════════════════════════════════════

func:test_kill = NIL() {
    drop(println("=== Kill ==="));

    int64:sigusr2 = aria_libc_posix_SIGUSR2();
    int64:sigterm = aria_libc_posix_SIGTERM();

    // Trap SIGUSR2
    int64:trc = aria_libc_posix_signal_trap(sigusr2);
    drop(assert_eq(trc, 0i64, "trap SIGUSR2"));

    // Test kill: spawn a sleeping child, then kill it
    int64:child = aria_libc_posix_spawn_bg("sleep 30");
    drop(assert_gt(child, 0i64, "spawn_bg returns child pid"));

    int64:krc = aria_libc_posix_kill(child, sigterm);
    drop(assert_eq(krc, 0i64, "kill(child, SIGTERM) returns 0"));

    // Wait for the killed child to collect it
    int64:wrc = aria_libc_posix_waitpid(child, 0i64);
    drop(assert_gte(wrc, 0i64, "waitpid after kill"));

    // Reset
    int64:rst = aria_libc_posix_signal_reset(sigusr2);
    drop(assert_eq(rst, 0i64, "signal_reset returns 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Main
// ══════════════════════════════════════════════════════════════════════

func:failsafe = int32(tbb32:err) {
    drop(println("FAILSAFE triggered"));
    exit(1i32);
};

func:main = int32() {
    drop(println("aria-libc Extended POSIX Tests"));
    drop(println("=============================="));

    drop(test_signal_constants());
    drop(test_signal_handling());
    drop(test_signal_ignore());
    drop(test_spawn());
    drop(test_fork_waitpid());
    drop(test_pipe());
    drop(test_dup());
    drop(test_mmap_constants());
    drop(test_mmap_bytes());
    drop(test_mmap_data());
    drop(test_mmap_protect());
    drop(test_error());
    drop(test_kill());

    drop(println("=============================="));
    drop(print("PASS: " + string_from_int(pass_count)));
    drop(print("FAIL: " + string_from_int(fail_count)));

    if (fail_count > 0i64) {
        exit(1i32);
    }
    exit(0i32);
};
