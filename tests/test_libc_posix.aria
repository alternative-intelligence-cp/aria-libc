// test_libc_posix.aria — Tests for aria-libc Extended POSIX wrappers
//
// Compile:
//   ariac test_libc_posix.aria -o test_libc_posix -L../shim -laria_libc_posix
//
// Run:
//   LD_LIBRARY_PATH=../shim ./test_libc_posix

extern "aria_libc_posix" {
    func:aria_libc_posix_errno = int64();
    func:aria_libc_posix_strerror = string(int64:errnum);

    // Signal constants
    func:aria_libc_posix_SIGHUP = int64();
    func:aria_libc_posix_SIGINT = int64();
    func:aria_libc_posix_SIGQUIT = int64();
    func:aria_libc_posix_SIGILL = int64();
    func:aria_libc_posix_SIGABRT = int64();
    func:aria_libc_posix_SIGFPE = int64();
    func:aria_libc_posix_SIGKILL = int64();
    func:aria_libc_posix_SIGSEGV = int64();
    func:aria_libc_posix_SIGPIPE = int64();
    func:aria_libc_posix_SIGALRM = int64();
    func:aria_libc_posix_SIGTERM = int64();
    func:aria_libc_posix_SIGUSR1 = int64();
    func:aria_libc_posix_SIGUSR2 = int64();
    func:aria_libc_posix_SIGCHLD = int64();
    func:aria_libc_posix_SIGCONT = int64();
    func:aria_libc_posix_SIGSTOP = int64();
    func:aria_libc_posix_SIGTSTP = int64();

    // Signal handling
    func:aria_libc_posix_signal_trap = int64(int64:signum);
    func:aria_libc_posix_signal_check = int64(int64:signum);
    func:aria_libc_posix_signal_reset = int64(int64:signum);
    func:aria_libc_posix_signal_ignore = int64(int64:signum);
    func:aria_libc_posix_raise = int64(int64:signum);
    func:aria_libc_posix_kill = int64(int64:pid, int64:signum);

    // Fork / exec / wait
    func:aria_libc_posix_fork = int64();
    func:aria_libc_posix_waitpid = int64(int64:pid, int64:flags);
    func:aria_libc_posix_WNOHANG = int64();
    func:aria_libc_posix_wait_exited = int64();
    func:aria_libc_posix_wait_status = int64();
    func:aria_libc_posix_wait_signaled = int64();
    func:aria_libc_posix_wait_termsig = int64();
    func:aria_libc_posix_exec_shell = int64(string:cmd);
    func:aria_libc_posix_spawn = int64(string:cmd);
    func:aria_libc_posix_spawn_bg = int64(string:cmd);
    func:aria_libc_posix_exit_now = void(int64:code);

    // Pipe + dup
    func:aria_libc_posix_pipe_create = int64();
    func:aria_libc_posix_pipe_read_fd = int64();
    func:aria_libc_posix_pipe_write_fd = int64();
    func:aria_libc_posix_dup = int64(int64:oldfd);
    func:aria_libc_posix_dup2 = int64(int64:oldfd, int64:newfd);
    func:aria_libc_posix_fd_write_string = int64(int64:fd, string:data);
    func:aria_libc_posix_fd_read_string = string(int64:fd, int64:max_bytes);
    func:aria_libc_posix_fd_close = int64(int64:fd);

    // mmap constants
    func:aria_libc_posix_PROT_NONE = int64();
    func:aria_libc_posix_PROT_READ = int64();
    func:aria_libc_posix_PROT_WRITE = int64();
    func:aria_libc_posix_PROT_EXEC = int64();
    func:aria_libc_posix_MAP_SHARED = int64();
    func:aria_libc_posix_MAP_PRIVATE = int64();
    func:aria_libc_posix_MAP_ANONYMOUS = int64();
    func:aria_libc_posix_MAP_FIXED = int64();
    func:aria_libc_posix_MS_ASYNC = int64();
    func:aria_libc_posix_MS_SYNC = int64();
    func:aria_libc_posix_MS_INVALIDATE = int64();

    // mmap operations
    func:aria_libc_posix_mmap = int64(int64:length, int64:prot, int64:flags, int64:fd, int64:offset);
    func:aria_libc_posix_munmap = int64(int64:handle);
    func:aria_libc_posix_mprotect = int64(int64:handle, int64:prot);
    func:aria_libc_posix_msync = int64(int64:handle, int64:flags);
    func:aria_libc_posix_mmap_length = int64(int64:handle);
    func:aria_libc_posix_mmap_read_byte = int64(int64:handle, int64:offset);
    func:aria_libc_posix_mmap_write_byte = int64(int64:handle, int64:offset, int64:value);
    func:aria_libc_posix_mmap_read_int64 = int64(int64:handle, int64:offset);
    func:aria_libc_posix_mmap_write_int64 = int64(int64:handle, int64:offset, int64:value);
    func:aria_libc_posix_mmap_to_string = string(int64:handle, int64:offset, int64:length);
    func:aria_libc_posix_mmap_from_string = int64(int64:handle, int64:offset, string:data);
}

int64:pass_count = 0i64;
int64:fail_count = 0i64;

func:assert_eq = NIL(int64:actual, int64:expected, string:msg) {
    if (actual == expected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected: " + string_from_int(expected)));
        drop(print("    actual:   " + string_from_int(actual)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_neq = NIL(int64:actual, int64:unexpected, string:msg) {
    if (actual != unexpected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    should not be: " + string_from_int(unexpected)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_gt = NIL(int64:actual, int64:threshold, string:msg) {
    if (actual > threshold) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected > " + string_from_int(threshold)));
        drop(print("    actual:    " + string_from_int(actual)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_gte = NIL(int64:actual, int64:threshold, string:msg) {
    if (actual >= threshold) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected >= " + string_from_int(threshold)));
        drop(print("    actual:     " + string_from_int(actual)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_str_eq = NIL(string:actual, string:expected, string:msg) {
    if (actual == expected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected: " + expected));
        drop(print("    actual:   " + actual));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_str_neq = NIL(string:actual, string:unexpected, string:msg) {
    if (actual != unexpected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    should not be: " + unexpected));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Signal constants
// ══════════════════════════════════════════════════════════════════════

func:test_signal_constants = NIL() {
    drop(println("=== Signal Constants ==="));

    drop(assert_gt(aria_libc_posix_SIGHUP(), 0i64, "SIGHUP > 0"));
    drop(assert_gt(aria_libc_posix_SIGINT(), 0i64, "SIGINT > 0"));
    drop(assert_gt(aria_libc_posix_SIGQUIT(), 0i64, "SIGQUIT > 0"));
    drop(assert_gt(aria_libc_posix_SIGKILL(), 0i64, "SIGKILL > 0"));
    drop(assert_gt(aria_libc_posix_SIGTERM(), 0i64, "SIGTERM > 0"));
    drop(assert_gt(aria_libc_posix_SIGUSR1(), 0i64, "SIGUSR1 > 0"));
    drop(assert_gt(aria_libc_posix_SIGUSR2(), 0i64, "SIGUSR2 > 0"));
    drop(assert_gt(aria_libc_posix_SIGCHLD(), 0i64, "SIGCHLD > 0"));
    drop(assert_gt(aria_libc_posix_SIGPIPE(), 0i64, "SIGPIPE > 0"));
    drop(assert_gt(aria_libc_posix_SIGALRM(), 0i64, "SIGALRM > 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Signal trap / check / raise
// ══════════════════════════════════════════════════════════════════════

func:test_signal_handling = NIL() {
    drop(println("=== Signal Handling ==="));

    int64:sigusr1 = aria_libc_posix_SIGUSR1();

    // Trap SIGUSR1
    int64:rc = aria_libc_posix_signal_trap(sigusr1);
    drop(assert_eq(rc, 0i64, "signal_trap(SIGUSR1) returns 0"));

    // Before raising — check should return 0
    int64:chk = aria_libc_posix_signal_check(sigusr1);
    drop(assert_eq(chk, 0i64, "signal_check before raise = 0"));

    // Raise SIGUSR1 to self
    int64:rrc = aria_libc_posix_raise(sigusr1);
    drop(assert_eq(rrc, 0i64, "raise(SIGUSR1) returns 0"));

    // Check — should return 1 and clear
    int64:chk2 = aria_libc_posix_signal_check(sigusr1);
    drop(assert_eq(chk2, 1i64, "signal_check after raise = 1"));

    // Second check — should be cleared
    int64:chk3 = aria_libc_posix_signal_check(sigusr1);
    drop(assert_eq(chk3, 0i64, "signal_check after clear = 0"));

    // Reset to default
    int64:rst = aria_libc_posix_signal_reset(sigusr1);
    drop(assert_eq(rst, 0i64, "signal_reset(SIGUSR1) returns 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Signal ignore
// ══════════════════════════════════════════════════════════════════════

func:test_signal_ignore = NIL() {
    drop(println("=== Signal Ignore ==="));

    int64:sigpipe_val = aria_libc_posix_SIGPIPE();

    // Ignore SIGPIPE (common pattern for network code)
    int64:rc = aria_libc_posix_signal_ignore(sigpipe_val);
    drop(assert_eq(rc, 0i64, "signal_ignore(SIGPIPE) returns 0"));

    // Raise it — should not crash since it's ignored
    int64:rrc = aria_libc_posix_raise(sigpipe_val);
    drop(assert_eq(rrc, 0i64, "raise(SIGPIPE) after ignore = 0"));

    // Reset to default
    int64:rst = aria_libc_posix_signal_reset(sigpipe_val);
    drop(assert_eq(rst, 0i64, "signal_reset(SIGPIPE) returns 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Fork + spawn
// ══════════════════════════════════════════════════════════════════════

func:test_spawn = NIL() {
    drop(println("=== Spawn ==="));

    // spawn("true") should return 0
    int64:rc1 = aria_libc_posix_spawn("true");
    drop(assert_eq(rc1, 0i64, "spawn(true) returns 0"));

    // spawn("false") should return non-zero
    int64:rc2 = aria_libc_posix_spawn("false");
    drop(assert_gt(rc2, 0i64, "spawn(false) returns > 0"));

    // spawn("echo hello") should return 0
    int64:rc3 = aria_libc_posix_spawn("echo hello > /dev/null");
    drop(assert_eq(rc3, 0i64, "spawn(echo) returns 0"));

    // spawn_bg returns child PID
    int64:cpid = aria_libc_posix_spawn_bg("sleep 0.01");
    drop(assert_gt(cpid, 0i64, "spawn_bg returns child pid > 0"));

    // Wait for it
    int64:wpid = aria_libc_posix_waitpid(cpid, 0i64);
    drop(assert_eq(wpid, cpid, "waitpid returns child pid"));

    // Check exit status
    int64:exited = aria_libc_posix_wait_exited();
    drop(assert_eq(exited, 1i64, "child exited normally"));

    int64:estat = aria_libc_posix_wait_status();
    drop(assert_eq(estat, 0i64, "child exit status = 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Fork + waitpid with WNOHANG
// ══════════════════════════════════════════════════════════════════════

func:test_fork_waitpid = NIL() {
    drop(println("=== Fork + Waitpid ==="));

    int64:wnohang = aria_libc_posix_WNOHANG();
    drop(assert_gt(wnohang, 0i64, "WNOHANG > 0"));

    // Fork a child that exits immediately
    int64:cpid = aria_libc_posix_spawn_bg("exit 42");
    drop(assert_gt(cpid, 0i64, "fork child pid > 0"));

    // Blocking wait
    int64:wpid = aria_libc_posix_waitpid(cpid, 0i64);
    drop(assert_eq(wpid, cpid, "waitpid returns child pid"));

    int64:exited = aria_libc_posix_wait_exited();
    drop(assert_eq(exited, 1i64, "child exited normally"));

    int64:estat = aria_libc_posix_wait_status();
    drop(assert_eq(estat, 42i64, "child exit code = 42"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Pipe
// ══════════════════════════════════════════════════════════════════════

func:test_pipe = NIL() {
    drop(println("=== Pipe ==="));

    // Create pipe
    int64:rc = aria_libc_posix_pipe_create();
    drop(assert_eq(rc, 0i64, "pipe_create returns 0"));

    int64:rfd = aria_libc_posix_pipe_read_fd();
    int64:wfd = aria_libc_posix_pipe_write_fd();
    drop(assert_gte(rfd, 0i64, "pipe read fd >= 0"));
    drop(assert_gte(wfd, 0i64, "pipe write fd >= 0"));
    drop(assert_neq(rfd, wfd, "read fd != write fd"));

    // Write to pipe
    int64:written = aria_libc_posix_fd_write_string(wfd, "hello pipe");
    drop(assert_eq(written, 10i64, "wrote 10 bytes to pipe"));

    // Close write end so read doesn't block
    int64:crc = aria_libc_posix_fd_close(wfd);
    drop(assert_eq(crc, 0i64, "close write end returns 0"));

    // Read from pipe
    string:data = aria_libc_posix_fd_read_string(rfd, 256i64);
    drop(assert_str_eq(data, "hello pipe", "read from pipe matches"));

    // Close read end
    int64:crc2 = aria_libc_posix_fd_close(rfd);
    drop(assert_eq(crc2, 0i64, "close read end returns 0"));

    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════════
// Test: Dup
// ══════════════════════════════════════════════════════════════════════

func:test_dup = NIL() {
    drop(println("=== Dup ==="));

    // Create a pipe and dup the write end
    int64:rc = aria_libc_posix_pipe_create();
    drop(assert_eq(rc, 0i64, "pipe_create for dup test"));

    int64:rfd = aria_libc_posix_pipe_read_fd();
    int64:wfd = aria_libc_posix_pipe_write_fd();

    // Dup write fd
    int64:dfd = aria_libc_posix_dup(wfd);
    drop(assert_gte(dfd, 0i64, "dup returns new fd >= 0"));
    drop(assert_neq(dfd, wfd, "dup fd != original fd"));

    // Write via duped fd
    int64:written = aria_libc_posix_fd_write_string(dfd, "duped");
    drop(assert_eq(written, 5i64, "wrote 5 bytes via duped fd"));

    // Close both write fds
    drop(aria_libc_posix_fd_close(wfd));
    drop(aria_libc_posix_fd_close(dfd));

    // Read from read end
    string:data = aria_libc_posix_fd_read_string(rfd, 256i64);
    drop(assert_str_eq(data, "duped", "read via pipe after dup write"));

    drop(aria_libc_posix_fd_close(rfd));

    pass(NIL);
};

