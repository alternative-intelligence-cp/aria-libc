// test_libc_math.aria — Tests for aria-libc Math wrappers
//
// Compile:
//   ariac test_libc_math.aria -o test_libc_math -L../shim -laria_libc_math -lm
//
// Run:
//   LD_LIBRARY_PATH=../shim ./test_libc_math

extern "aria_libc_math" {
    func:aria_libc_math_errno = int64();
    func:aria_libc_math_strerror = string(int64:errnum);

    func:aria_libc_math_pi = flt64();
    func:aria_libc_math_e = flt64();

    func:aria_libc_math_sin = flt64(flt64:x);
    func:aria_libc_math_cos = flt64(flt64:x);
    func:aria_libc_math_tan = flt64(flt64:x);
    func:aria_libc_math_asin = flt64(flt64:x);
    func:aria_libc_math_acos = flt64(flt64:x);
    func:aria_libc_math_atan = flt64(flt64:x);
    func:aria_libc_math_atan2 = flt64(flt64:y, flt64:x);

    func:aria_libc_math_sqrt = flt64(flt64:x);
    func:aria_libc_math_pow = flt64(flt64:base, flt64:exponent);
    func:aria_libc_math_exp = flt64(flt64:x);
    func:aria_libc_math_log = flt64(flt64:x);
    func:aria_libc_math_log10 = flt64(flt64:x);

    func:aria_libc_math_floor = flt64(flt64:x);
    func:aria_libc_math_ceil = flt64(flt64:x);
    func:aria_libc_math_round = flt64(flt64:x);
    func:aria_libc_math_fabs = flt64(flt64:x);
    func:aria_libc_math_fmod = flt64(flt64:x, flt64:y);

    func:aria_libc_math_to_int = int64(flt64:x);
    func:aria_libc_math_approx_eq = int64(flt64:a, flt64:b, flt64:epsilon);
    func:aria_libc_math_to_string = string(flt64:x);
}

int64:pass_count = 0i64;
int64:fail_count = 0i64;

func:assert_eq = NIL(int64:actual, int64:expected, string:msg) {
    if (actual == expected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected: " + string_from_int(expected)));
        drop(print("    actual:   " + string_from_int(actual)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_flt_near = NIL(flt64:actual, flt64:expected, flt64:epsilon, string:msg) {
    int64:near = aria_libc_math_approx_eq(actual, expected, epsilon);
    if (near == 1i64) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        string:actual_str = aria_libc_math_to_string(actual);
        string:expected_str = aria_libc_math_to_string(expected);
        drop(print("    expected: " + expected_str));
        drop(print("    actual:   " + actual_str));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:failsafe = int32(tbb32:err) {
    drop(print("FAILSAFE triggered"));
    exit(1);
};

func:main = int32() {
    drop(print("=== aria-libc Math Tests ==="));
    drop(print(""));

    flt64:eps = 0.000001;

    // Get constants for use in tests
    flt64:pi_val = aria_libc_math_pi();
    flt64:e_val = aria_libc_math_e();

    // ── Test 1: Constants ────────────────────────────────────────
    drop(print("[Test 1] Constants"));
    drop(assert_flt_near(pi_val, 3.14159265358979, eps, "PI ~ 3.14159"));
    drop(assert_flt_near(e_val, 2.71828182845904, eps, "E ~ 2.71828"));

    // ── Test 2: sin ──────────────────────────────────────────────
    drop(print("[Test 2] sin"));
    flt64:sin0 = aria_libc_math_sin(0.0);
    drop(assert_flt_near(sin0, 0.0, eps, "sin(0) = 0"));

    flt64:half_pi = pi_val * 0.5;
    flt64:sin_hp = aria_libc_math_sin(half_pi);
    drop(assert_flt_near(sin_hp, 1.0, eps, "sin(pi/2) = 1"));

    flt64:sin_pi = aria_libc_math_sin(pi_val);
    drop(assert_flt_near(sin_pi, 0.0, eps, "sin(pi) ~ 0"));

    // ── Test 3: cos ──────────────────────────────────────────────
    drop(print("[Test 3] cos"));
    flt64:cos0 = aria_libc_math_cos(0.0);
    drop(assert_flt_near(cos0, 1.0, eps, "cos(0) = 1"));

    flt64:cos_hp = aria_libc_math_cos(half_pi);
    drop(assert_flt_near(cos_hp, 0.0, eps, "cos(pi/2) ~ 0"));

    flt64:neg1 = 0.0 - 1.0;
    flt64:cos_pi = aria_libc_math_cos(pi_val);
    drop(assert_flt_near(cos_pi, neg1, eps, "cos(pi) = -1"));

    // ── Test 4: tan ──────────────────────────────────────────────
    drop(print("[Test 4] tan"));
    flt64:tan0 = aria_libc_math_tan(0.0);
    drop(assert_flt_near(tan0, 0.0, eps, "tan(0) = 0"));

    flt64:quarter_pi = pi_val * 0.25;
    flt64:tan_qp = aria_libc_math_tan(quarter_pi);
    drop(assert_flt_near(tan_qp, 1.0, eps, "tan(pi/4) = 1"));

    // ── Test 5: asin ─────────────────────────────────────────────
    drop(print("[Test 5] asin"));
    flt64:asin0 = aria_libc_math_asin(0.0);
    drop(assert_flt_near(asin0, 0.0, eps, "asin(0) = 0"));

    flt64:asin1 = aria_libc_math_asin(1.0);
    drop(assert_flt_near(asin1, half_pi, eps, "asin(1) = pi/2"));

    // ── Test 6: acos ─────────────────────────────────────────────
    drop(print("[Test 6] acos"));
    flt64:acos1 = aria_libc_math_acos(1.0);
    drop(assert_flt_near(acos1, 0.0, eps, "acos(1) = 0"));

    flt64:acos0 = aria_libc_math_acos(0.0);
    drop(assert_flt_near(acos0, half_pi, eps, "acos(0) = pi/2"));

    // ── Test 7: atan ─────────────────────────────────────────────
    drop(print("[Test 7] atan"));
    flt64:atan0 = aria_libc_math_atan(0.0);
    drop(assert_flt_near(atan0, 0.0, eps, "atan(0) = 0"));

    flt64:atan1 = aria_libc_math_atan(1.0);
    drop(assert_flt_near(atan1, quarter_pi, eps, "atan(1) = pi/4"));

    // ── Test 8: atan2 ────────────────────────────────────────────
    drop(print("[Test 8] atan2"));
    flt64:atan2_11 = aria_libc_math_atan2(1.0, 1.0);
    drop(assert_flt_near(atan2_11, quarter_pi, eps, "atan2(1,1) = pi/4"));

    flt64:atan2_01 = aria_libc_math_atan2(0.0, 1.0);
    drop(assert_flt_near(atan2_01, 0.0, eps, "atan2(0,1) = 0"));

    // ── Test 9: sqrt ─────────────────────────────────────────────
    drop(print("[Test 9] sqrt"));
    flt64:sqrt4 = aria_libc_math_sqrt(4.0);
    drop(assert_flt_near(sqrt4, 2.0, eps, "sqrt(4) = 2"));

    flt64:sqrt9 = aria_libc_math_sqrt(9.0);
    drop(assert_flt_near(sqrt9, 3.0, eps, "sqrt(9) = 3"));

    flt64:sqrt0 = aria_libc_math_sqrt(0.0);
    drop(assert_flt_near(sqrt0, 0.0, eps, "sqrt(0) = 0"));

    // ── Test 10: pow ─────────────────────────────────────────────
    drop(print("[Test 10] pow"));
    flt64:pow2_10 = aria_libc_math_pow(2.0, 10.0);
    drop(assert_flt_near(pow2_10, 1024.0, eps, "pow(2,10) = 1024"));

    flt64:pow3_3 = aria_libc_math_pow(3.0, 3.0);
    drop(assert_flt_near(pow3_3, 27.0, eps, "pow(3,3) = 27"));

    flt64:pow2_0 = aria_libc_math_pow(2.0, 0.0);
    drop(assert_flt_near(pow2_0, 1.0, eps, "pow(2,0) = 1"));

    // ── Test 11: exp / log ───────────────────────────────────────
    drop(print("[Test 11] exp / log"));
    flt64:exp0 = aria_libc_math_exp(0.0);
    drop(assert_flt_near(exp0, 1.0, eps, "exp(0) = 1"));

    flt64:exp1 = aria_libc_math_exp(1.0);
    drop(assert_flt_near(exp1, e_val, eps, "exp(1) = e"));

    flt64:log1 = aria_libc_math_log(1.0);
    drop(assert_flt_near(log1, 0.0, eps, "log(1) = 0"));

    flt64:log_e = aria_libc_math_log(e_val);
    drop(assert_flt_near(log_e, 1.0, eps, "log(e) = 1"));

    // ── Test 12: log10 ───────────────────────────────────────────
    drop(print("[Test 12] log10"));
    flt64:log10_1 = aria_libc_math_log10(1.0);
    drop(assert_flt_near(log10_1, 0.0, eps, "log10(1) = 0"));

    flt64:log10_100 = aria_libc_math_log10(100.0);
    drop(assert_flt_near(log10_100, 2.0, eps, "log10(100) = 2"));

    // ── Test 13: floor ───────────────────────────────────────────
    drop(print("[Test 13] floor"));
    flt64:floor1 = aria_libc_math_floor(3.7);
    int64:floor1_i = aria_libc_math_to_int(floor1);
    drop(assert_eq(floor1_i, 3i64, "floor(3.7) = 3"));

    flt64:neg_3_2 = 0.0 - 3.2;
    flt64:floor2 = aria_libc_math_floor(neg_3_2);
    int64:floor2_i = aria_libc_math_to_int(floor2);
    int64:neg4 = 0i64 - 4i64;
    drop(assert_eq(floor2_i, neg4, "floor(-3.2) = -4"));

    flt64:floor3 = aria_libc_math_floor(5.0);
    int64:floor3_i = aria_libc_math_to_int(floor3);
    drop(assert_eq(floor3_i, 5i64, "floor(5.0) = 5"));

    // ── Test 14: ceil ────────────────────────────────────────────
    drop(print("[Test 14] ceil"));
    flt64:ceil1 = aria_libc_math_ceil(3.2);
    int64:ceil1_i = aria_libc_math_to_int(ceil1);
    drop(assert_eq(ceil1_i, 4i64, "ceil(3.2) = 4"));

    flt64:neg_3_7 = 0.0 - 3.7;
    flt64:ceil2 = aria_libc_math_ceil(neg_3_7);
    int64:ceil2_i = aria_libc_math_to_int(ceil2);
    int64:neg3 = 0i64 - 3i64;
    drop(assert_eq(ceil2_i, neg3, "ceil(-3.7) = -3"));

    flt64:ceil3 = aria_libc_math_ceil(5.0);
    int64:ceil3_i = aria_libc_math_to_int(ceil3);
    drop(assert_eq(ceil3_i, 5i64, "ceil(5.0) = 5"));

    // ── Test 15: round ───────────────────────────────────────────
    drop(print("[Test 15] round"));
    flt64:round1 = aria_libc_math_round(3.5);
    int64:round1_i = aria_libc_math_to_int(round1);
    drop(assert_eq(round1_i, 4i64, "round(3.5) = 4"));

    flt64:round2 = aria_libc_math_round(3.4);
    int64:round2_i = aria_libc_math_to_int(round2);
    drop(assert_eq(round2_i, 3i64, "round(3.4) = 3"));

    flt64:neg_3_5 = 0.0 - 3.5;
    flt64:round3 = aria_libc_math_round(neg_3_5);
    int64:round3_i = aria_libc_math_to_int(round3);
    drop(assert_eq(round3_i, neg4, "round(-3.5) = -4"));

    // ── Test 16: fabs ────────────────────────────────────────────
    drop(print("[Test 16] fabs"));
    flt64:neg_5_5 = 0.0 - 5.5;
    flt64:fabs1 = aria_libc_math_fabs(neg_5_5);
    drop(assert_flt_near(fabs1, 5.5, eps, "fabs(-5.5) = 5.5"));

    flt64:fabs2 = aria_libc_math_fabs(3.2);
    drop(assert_flt_near(fabs2, 3.2, eps, "fabs(3.2) = 3.2"));

    // ── Test 17: fmod ────────────────────────────────────────────
    drop(print("[Test 17] fmod"));
    flt64:fmod1 = aria_libc_math_fmod(10.5, 3.0);
    drop(assert_flt_near(fmod1, 1.5, eps, "fmod(10.5, 3.0) = 1.5"));

    flt64:fmod2 = aria_libc_math_fmod(7.0, 2.0);
    drop(assert_flt_near(fmod2, 1.0, eps, "fmod(7.0, 2.0) = 1.0"));

    // ── Test 18: to_int ──────────────────────────────────────────
    drop(print("[Test 18] to_int"));
    int64:ti1 = aria_libc_math_to_int(3.7);
    drop(assert_eq(ti1, 3i64, "to_int(3.7) = 3"));

    flt64:neg_3_7b = 0.0 - 3.7;
    int64:ti2 = aria_libc_math_to_int(neg_3_7b);
    drop(assert_eq(ti2, neg3, "to_int(-3.7) = -3"));

    int64:ti3 = aria_libc_math_to_int(0.0);
    drop(assert_eq(ti3, 0i64, "to_int(0.0) = 0"));

    // ── Summary ──────────────────────────────────────────────────
    drop(print(""));
    drop(print("=== Results ==="));
    drop(print("PASS: " + string_from_int(pass_count)));
    drop(print("FAIL: " + string_from_int(fail_count)));

    if (fail_count > 0i64) {
        exit(1);
    }

    exit(0);
};
