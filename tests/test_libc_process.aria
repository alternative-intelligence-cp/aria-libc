// test_libc_process.aria — Tests for aria-libc Process wrappers
//
// Compile:
//   ariac test_libc_process.aria -o test_libc_process -L../shim -laria_libc_process
//
// Run:
//   LD_LIBRARY_PATH=../shim ./test_libc_process

extern "aria_libc_process" {
    func:aria_libc_process_errno = int64();
    func:aria_libc_process_strerror = string(int64:errnum);

    func:aria_libc_process_get_errno = int64();
    func:aria_libc_process_get_strerror = string(int64:errnum);

    func:aria_libc_process_getenv = string(string:name);
    func:aria_libc_process_getenv_exists = int64(string:name);
    func:aria_libc_process_setenv = int64(string:name, string:value);
    func:aria_libc_process_unsetenv = int64(string:name);

    func:aria_libc_process_run = int64(string:command);

    func:aria_libc_process_getpid = int64();
    func:aria_libc_process_getppid = int64();
    func:aria_libc_process_getuid = int64();
    func:aria_libc_process_getgid = int64();

    func:aria_libc_process_getcwd = string();
    func:aria_libc_process_chdir = int64(string:path);
}

int64:pass_count = 0i64;
int64:fail_count = 0i64;

func:assert_eq = NIL(int64:actual, int64:expected, string:msg) {
    if (actual == expected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected: " + string_from_int(expected)));
        drop(print("    actual:   " + string_from_int(actual)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_neq = NIL(int64:actual, int64:unexpected, string:msg) {
    if (actual != unexpected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    should not be: " + string_from_int(unexpected)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_str_eq = NIL(string:actual, string:expected, string:msg) {
    if (actual == expected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected: " + expected));
        drop(print("    actual:   " + actual));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_str_neq = NIL(string:actual, string:unexpected, string:msg) {
    if (actual != unexpected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    should not be: " + unexpected));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:failsafe = int32(tbb32:err) {
    drop(print("FAILSAFE triggered"));
    exit(1);
};

func:main = int32() {
    drop(print("=== aria-libc Process Tests ==="));
    drop(print(""));

    // ── Test 1: getenv ───────────────────────────────────────────
    drop(print("[Test 1] getenv"));
    string:home = aria_libc_process_getenv("HOME");
    drop(assert_str_neq(home, "", "getenv(HOME) is non-empty"));

    int64:home_exists = aria_libc_process_getenv_exists("HOME");
    drop(assert_eq(home_exists, 1i64, "getenv_exists(HOME) = 1"));

    string:novar = aria_libc_process_getenv("ARIA_LIBC_NONEXISTENT_VAR_XYZ");
    drop(assert_str_eq(novar, "", "getenv(nonexistent) = empty"));

    int64:novar_exists = aria_libc_process_getenv_exists("ARIA_LIBC_NONEXISTENT_VAR_XYZ");
    drop(assert_eq(novar_exists, 0i64, "getenv_exists(nonexistent) = 0"));

    // ── Test 2: setenv / unsetenv ────────────────────────────────
    drop(print("[Test 2] setenv / unsetenv"));
    int64:set_result = aria_libc_process_setenv("ARIA_LIBC_TEST_VAR", "hello42");
    drop(assert_eq(set_result, 0i64, "setenv returns 0"));

    string:got = aria_libc_process_getenv("ARIA_LIBC_TEST_VAR");
    drop(assert_str_eq(got, "hello42", "getenv after setenv = hello42"));

    // Overwrite
    int64:set2 = aria_libc_process_setenv("ARIA_LIBC_TEST_VAR", "updated");
    drop(assert_eq(set2, 0i64, "setenv overwrite returns 0"));

    string:got2 = aria_libc_process_getenv("ARIA_LIBC_TEST_VAR");
    drop(assert_str_eq(got2, "updated", "getenv after overwrite = updated"));

    // Unset
    int64:unset_result = aria_libc_process_unsetenv("ARIA_LIBC_TEST_VAR");
    drop(assert_eq(unset_result, 0i64, "unsetenv returns 0"));

    int64:gone = aria_libc_process_getenv_exists("ARIA_LIBC_TEST_VAR");
    drop(assert_eq(gone, 0i64, "var gone after unsetenv"));

    // ── Test 3: system (run) ─────────────────────────────────────
    drop(print("[Test 3] system (run)"));
    int64:run1 = aria_libc_process_run("true");
    drop(assert_eq(run1, 0i64, "run(true) = 0"));

    int64:run2 = aria_libc_process_run("false");
    drop(assert_eq(run2, 1i64, "run(false) = 1"));

    // ── Test 4: getpid / getppid ─────────────────────────────────
    drop(print("[Test 4] getpid / getppid"));
    int64:pid = aria_libc_process_getpid();
    int64:pid_pos = 0i64;
    if (pid > 0i64) {
        pid_pos = 1i64;
    }
    drop(assert_eq(pid_pos, 1i64, "getpid() > 0"));

    int64:ppid = aria_libc_process_getppid();
    int64:ppid_pos = 0i64;
    if (ppid > 0i64) {
        ppid_pos = 1i64;
    }
    drop(assert_eq(ppid_pos, 1i64, "getppid() > 0"));

    // pid and ppid should differ
    int64:pid_neq_ppid = 0i64;
    if (pid != ppid) {
        pid_neq_ppid = 1i64;
    }
    drop(assert_eq(pid_neq_ppid, 1i64, "getpid() != getppid()"));

    // ── Test 5: getuid / getgid ──────────────────────────────────
    drop(print("[Test 5] getuid / getgid"));
    int64:uid = aria_libc_process_getuid();
    int64:uid_valid = 0i64;
    int64:neg1 = 0i64 - 1i64;
    if (uid > neg1) {
        uid_valid = 1i64;
    }
    drop(assert_eq(uid_valid, 1i64, "getuid() >= 0"));

    int64:gid = aria_libc_process_getgid();
    int64:gid_valid = 0i64;
    if (gid > neg1) {
        gid_valid = 1i64;
    }
    drop(assert_eq(gid_valid, 1i64, "getgid() >= 0"));

    // ── Test 6: getcwd ───────────────────────────────────────────
    drop(print("[Test 6] getcwd"));
    string:cwd = aria_libc_process_getcwd();
    drop(assert_str_neq(cwd, "", "getcwd() is non-empty"));

    // cwd should start with /
    int64:cwd_len = string_length(cwd);
    int64:has_slash = 0i64;
    if (cwd_len > 0i64) {
        string:first = string_substring(cwd, 0i64, 1i64);
        if (first == "/") {
            has_slash = 1i64;
        }
    }
    drop(assert_eq(has_slash, 1i64, "getcwd() starts with /"));

    // ── Test 7: chdir ────────────────────────────────────────────
    drop(print("[Test 7] chdir"));
    string:orig_cwd = aria_libc_process_getcwd();

    int64:cd_result = aria_libc_process_chdir("/tmp");
    drop(assert_eq(cd_result, 0i64, "chdir(/tmp) returns 0"));

    string:new_cwd = aria_libc_process_getcwd();
    drop(assert_str_eq(new_cwd, "/tmp", "getcwd() after chdir = /tmp"));

    // Restore original cwd
    int64:cd_back = aria_libc_process_chdir(orig_cwd);
    drop(assert_eq(cd_back, 0i64, "chdir back returns 0"));

    // Bad chdir
    int64:cd_bad = aria_libc_process_chdir("/nonexistent_dir_xyz_123");
    drop(assert_eq(cd_bad, neg1, "chdir(bad) returns -1"));

    // ── Test 8: global errno ─────────────────────────────────────
    drop(print("[Test 8] global errno"));
    // After the bad chdir, errno should be set
    int64:err_val = aria_libc_process_get_errno();
    int64:err_set = 0i64;
    if (err_val > 0i64) {
        err_set = 1i64;
    }
    drop(assert_eq(err_set, 1i64, "errno > 0 after bad chdir"));

    string:err_msg = aria_libc_process_get_strerror(err_val);
    drop(assert_str_neq(err_msg, "", "strerror returns non-empty"));

    // ── Summary ──────────────────────────────────────────────────
    drop(print(""));
    drop(print("=== Results ==="));
    drop(print("PASS: " + string_from_int(pass_count)));
    drop(print("FAIL: " + string_from_int(fail_count)));

    if (fail_count > 0i64) {
        exit(1);
    }

    exit(0);
};
