// Quick validation: does `use` import of pub func wrappers work now?
// This tests the BUG-001 fix against the actual aria-libc source file.

use "../src/aria_libc_io.aria".*;

func:failsafe = NIL(int32:code) {
    drop(println("FAILSAFE triggered"));
    pass(NIL);
};

func:main = int32() {
    int32:passed = 0i32;
    int32:failed = 0i32;

    // Test: write via pub wrapper (returns Result<int64>)
    int64:bytes = raw(libc_write_file("/tmp/aria_use_test.txt", "Hello via use import!\n"));
    if (bytes > 0i64) {
        drop(println("PASS: libc_write_file via use"));
        passed = passed + 1i32;
    } else {
        drop(println("FAIL: libc_write_file via use"));
        failed = failed + 1i32;
    }

    // Test: stat via pub wrapper
    int64:exists = raw(libc_stat_exists("/tmp/aria_use_test.txt"));
    if (exists == 1i64) {
        drop(println("PASS: libc_stat_exists via use"));
        passed = passed + 1i32;
    } else {
        drop(println("FAIL: libc_stat_exists via use"));
        failed = failed + 1i32;
    }

    // Test: read via pub wrapper
    string:content = raw(libc_read_file("/tmp/aria_use_test.txt"));
    int64:len = string_length(content);
    if (len == 22i64) {
        drop(println("PASS: libc_read_file via use"));
        passed = passed + 1i32;
    } else {
        drop(println("FAIL: libc_read_file via use"));
        failed = failed + 1i32;
    }

    // Cleanup
    drop(libc_unlink("/tmp/aria_use_test.txt"));

    if (failed == 0i32) {
        drop(println("ALL 3 USE-IMPORT TESTS PASSED"));
    } else {
        drop(println("SOME TESTS FAILED"));
    }

    pass(0i32);
};
