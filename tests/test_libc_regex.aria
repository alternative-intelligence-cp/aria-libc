// test_libc_regex.aria — Tests for aria-libc POSIX regex wrappers
//
// Compile:
//   ariac test_libc_regex.aria -o test_libc_regex -L../shim -laria_libc_regex
//
// Run:
//   LD_LIBRARY_PATH=../shim ./test_libc_regex

extern "aria_libc_regex" {
    func:aria_libc_regex_errno = int64();
    func:aria_libc_regex_strerror = string(int64:e);
    func:aria_libc_regex_last_error = string();

    func:aria_libc_regex_REG_EXTENDED = int64();
    func:aria_libc_regex_REG_ICASE = int64();
    func:aria_libc_regex_REG_NEWLINE = int64();
    func:aria_libc_regex_REG_NOSUB = int64();

    func:aria_libc_regex_compile = int64(string:pattern, int64:flags);
    func:aria_libc_regex_release = int64(int64:handle);

    func:aria_libc_regex_is_match = int64(int64:handle, string:text);
    func:aria_libc_regex_exec = int64(int64:handle, string:text);
    func:aria_libc_regex_group_start = int64(int64:handle, int64:group);
    func:aria_libc_regex_group_end = int64(int64:handle, int64:group);
    func:aria_libc_regex_group_string = string(int64:handle, int64:group, string:text);

    func:aria_libc_regex_replace_first = string(int64:handle, string:text, string:replacement);
    func:aria_libc_regex_replace_all = string(int64:handle, string:text, string:replacement);

    func:aria_libc_regex_count_matches = int64(int64:handle, string:text);
}

// ══════════════════════════════════════════════════════════════════

func:assert_eq = NIL(int64:actual, int64:expected, string:msg) {
    if (actual == expected) {
        drop(print("  PASS: " + msg));
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected: " + string_from_int(expected)));
        drop(print("    actual:   " + string_from_int(actual)));
    }
    pass(NIL);
};

func:assert_gt = NIL(int64:actual, int64:threshold, string:msg) {
    if (actual > threshold) {
        drop(print("  PASS: " + msg));
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected > " + string_from_int(threshold)));
        drop(print("    actual:    " + string_from_int(actual)));
    }
    pass(NIL);
};

func:assert_gte = NIL(int64:actual, int64:threshold, string:msg) {
    if (actual >= threshold) {
        drop(print("  PASS: " + msg));
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected >= " + string_from_int(threshold)));
        drop(print("    actual:     " + string_from_int(actual)));
    }
    pass(NIL);
};

func:assert_str_eq = NIL(string:actual, string:expected, string:msg) {
    if (actual == expected) {
        drop(print("  PASS: " + msg));
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected: " + expected));
        drop(print("    actual:   " + actual));
    }
    pass(NIL);
};

func:assert_str_ne = NIL(string:actual, string:unexpected, string:msg) {
    if (actual != unexpected) {
        drop(print("  PASS: " + msg));
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    should not be: " + unexpected));
    }
    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════
// Test functions
// ══════════════════════════════════════════════════════════════════

func:test_constants = NIL() {
    drop(println("=== Regex Constants ==="));
    int64:ext = aria_libc_regex_REG_EXTENDED();
    int64:ic  = aria_libc_regex_REG_ICASE();
    int64:nl  = aria_libc_regex_REG_NEWLINE();
    int64:ns  = aria_libc_regex_REG_NOSUB();
    drop(assert_gt(ext, 0i64, "REG_EXTENDED > 0"));
    drop(assert_gt(ic, 0i64, "REG_ICASE > 0"));
    drop(assert_gt(nl, 0i64, "REG_NEWLINE > 0"));
    drop(assert_gt(ns, 0i64, "REG_NOSUB > 0"));
    pass(NIL);
};

func:test_compile_release = NIL() {
    drop(println("=== Compile / Release ==="));

    int64:flags = aria_libc_regex_REG_EXTENDED();

    int64:h = aria_libc_regex_compile("^hello", flags);
    drop(assert_gte(h, 0i64, "compile returns valid handle"));

    int64:rc = aria_libc_regex_release(h);
    drop(assert_eq(rc, 0i64, "release returns 0"));

    // Bad pattern
    int64:h2 = aria_libc_regex_compile("[invalid", flags);
    drop(assert_eq(h2, -1i64, "compile bad pattern returns -1"));

    string:err = aria_libc_regex_last_error();
    drop(assert_str_ne(err, "", "last_error non-empty after bad compile"));

    pass(NIL);
};

func:test_is_match = NIL() {
    drop(println("=== Is Match ==="));

    int64:flags = aria_libc_regex_REG_EXTENDED();

    int64:h = aria_libc_regex_compile("^[0-9]+$", flags);
    drop(assert_gte(h, 0i64, "compile digits pattern"));

    int64:m1 = aria_libc_regex_is_match(h, "12345");
    drop(assert_eq(m1, 1i64, "12345 matches ^[0-9]+$"));

    int64:m2 = aria_libc_regex_is_match(h, "hello");
    drop(assert_eq(m2, 0i64, "hello does not match ^[0-9]+$"));

    int64:m3 = aria_libc_regex_is_match(h, "123abc");
    drop(assert_eq(m3, 0i64, "123abc does not match ^[0-9]+$"));

    drop(aria_libc_regex_release(h));
    pass(NIL);
};

func:test_icase = NIL() {
    drop(println("=== Case Insensitive ==="));

    int64:ext = aria_libc_regex_REG_EXTENDED();
    int64:ic  = aria_libc_regex_REG_ICASE();
    // Combine flags with addition (bitwise OR equivalent for distinct bit flags)
    int64:flags = ext + ic;

    int64:h = aria_libc_regex_compile("hello", flags);
    drop(assert_gte(h, 0i64, "compile icase pattern"));

    int64:m1 = aria_libc_regex_is_match(h, "HELLO");
    drop(assert_eq(m1, 1i64, "HELLO matches hello (icase)"));

    int64:m2 = aria_libc_regex_is_match(h, "hElLo World");
    drop(assert_eq(m2, 1i64, "hElLo World matches (icase)"));

    drop(aria_libc_regex_release(h));
    pass(NIL);
};

func:test_exec_groups = NIL() {
    drop(println("=== Exec with Groups ==="));

    int64:flags = aria_libc_regex_REG_EXTENDED();

    // Pattern with capture groups: (year)-(month)-(day)
    int64:h = aria_libc_regex_compile("([0-9]{4})-([0-9]{2})-([0-9]{2})", flags);
    drop(assert_gte(h, 0i64, "compile date pattern"));

    string:text = "Date: 2026-03-29 is today";
    int64:ngroups = aria_libc_regex_exec(h, text);
    drop(assert_eq(ngroups, 4i64, "exec returns 4 groups (full + 3 captures)"));

    // Group 0 = entire match
    int64:s0 = aria_libc_regex_group_start(h, 0i64);
    int64:e0 = aria_libc_regex_group_end(h, 0i64);
    drop(assert_eq(s0, 6i64, "group 0 start = 6"));
    drop(assert_eq(e0, 16i64, "group 0 end = 16"));

    string:g0 = aria_libc_regex_group_string(h, 0i64, text);
    drop(assert_str_eq(g0, "2026-03-29", "group 0 = 2026-03-29"));

    // Group 1 = year
    string:g1 = aria_libc_regex_group_string(h, 1i64, text);
    drop(assert_str_eq(g1, "2026", "group 1 = 2026"));

    // Group 2 = month
    string:g2 = aria_libc_regex_group_string(h, 2i64, text);
    drop(assert_str_eq(g2, "03", "group 2 = 03"));

    // Group 3 = day
    string:g3 = aria_libc_regex_group_string(h, 3i64, text);
    drop(assert_str_eq(g3, "29", "group 3 = 29"));

    drop(aria_libc_regex_release(h));
    pass(NIL);
};

func:test_no_match = NIL() {
    drop(println("=== Exec No Match ==="));

    int64:flags = aria_libc_regex_REG_EXTENDED();
    int64:h = aria_libc_regex_compile("xyz", flags);
    drop(assert_gte(h, 0i64, "compile xyz"));

    int64:n = aria_libc_regex_exec(h, "hello world");
    drop(assert_eq(n, 0i64, "exec returns 0 for no match"));

    int64:s = aria_libc_regex_group_start(h, 0i64);
    drop(assert_eq(s, -1i64, "group_start -1 after no match"));

    drop(aria_libc_regex_release(h));
    pass(NIL);
};

func:test_replace_first = NIL() {
    drop(println("=== Replace First ==="));

    int64:flags = aria_libc_regex_REG_EXTENDED();
    int64:h = aria_libc_regex_compile("[0-9]+", flags);
    drop(assert_gte(h, 0i64, "compile number pattern"));

    string:result = aria_libc_regex_replace_first(h, "abc 123 def 456", "NUM");
    drop(assert_str_eq(result, "abc NUM def 456", "replace_first replaces only first"));

    // No match → original returned
    string:r2 = aria_libc_regex_replace_first(h, "no numbers here", "NUM");
    drop(assert_str_eq(r2, "no numbers here", "replace_first no match = original"));

    drop(aria_libc_regex_release(h));
    pass(NIL);
};

func:test_replace_all = NIL() {
    drop(println("=== Replace All ==="));

    int64:flags = aria_libc_regex_REG_EXTENDED();
    int64:h = aria_libc_regex_compile("[0-9]+", flags);
    drop(assert_gte(h, 0i64, "compile number pattern"));

    string:result = aria_libc_regex_replace_all(h, "abc 123 def 456 ghi 789", "N");
    drop(assert_str_eq(result, "abc N def N ghi N", "replace_all replaces all"));

    string:r2 = aria_libc_regex_replace_all(h, "no numbers", "N");
    drop(assert_str_eq(r2, "no numbers", "replace_all no match = original"));

    drop(aria_libc_regex_release(h));
    pass(NIL);
};

func:test_count = NIL() {
    drop(println("=== Count Matches ==="));

    int64:flags = aria_libc_regex_REG_EXTENDED();
    int64:h = aria_libc_regex_compile("[aeiou]", flags);
    drop(assert_gte(h, 0i64, "compile vowel pattern"));

    int64:c = aria_libc_regex_count_matches(h, "hello world");
    drop(assert_eq(c, 3i64, "hello world has 3 vowels"));

    int64:c2 = aria_libc_regex_count_matches(h, "xyz");
    drop(assert_eq(c2, 0i64, "xyz has 0 vowels"));

    drop(aria_libc_regex_release(h));
    pass(NIL);
};

func:test_error_reporting = NIL() {
    drop(println("=== Error Reporting ==="));

    int64:flags = aria_libc_regex_REG_EXTENDED();

    // Bad compile should produce error
    int64:h = aria_libc_regex_compile("(unclosed", flags);
    drop(assert_eq(h, -1i64, "bad compile returns -1"));

    int64:e = aria_libc_regex_errno();
    drop(assert_gt(e, 0i64, "errno > 0 after bad compile"));

    string:msg = aria_libc_regex_last_error();
    drop(assert_str_ne(msg, "", "last_error non-empty"));

    // Release with bad handle
    int64:rc = aria_libc_regex_release(99i64);
    drop(assert_eq(rc, -1i64, "release bad handle = -1"));

    pass(NIL);
};

func:test_email_pattern = NIL() {
    drop(println("=== Email Pattern ==="));

    int64:flags = aria_libc_regex_REG_EXTENDED();
    int64:h = aria_libc_regex_compile("([a-zA-Z0-9.]+)@([a-zA-Z0-9.]+)", flags);
    drop(assert_gte(h, 0i64, "compile email pattern"));

    string:text = "Contact: user@example.com for info";
    int64:n = aria_libc_regex_exec(h, text);
    drop(assert_eq(n, 3i64, "exec returns 3 groups (full + user + domain)"));

    string:full = aria_libc_regex_group_string(h, 0i64, text);
    drop(assert_str_eq(full, "user@example.com", "group 0 = full email"));

    string:user = aria_libc_regex_group_string(h, 1i64, text);
    drop(assert_str_eq(user, "user", "group 1 = user"));

    string:domain = aria_libc_regex_group_string(h, 2i64, text);
    drop(assert_str_eq(domain, "example.com", "group 2 = domain"));

    drop(aria_libc_regex_release(h));
    pass(NIL);
};

// ══════════════════════════════════════════════════════════════════
// Main
// ══════════════════════════════════════════════════════════════════

func:failsafe = int32(tbb32:err) {
    drop(println("Failsafe triggered"));
    exit(1i32);
};

func:main = int32() {
    drop(println("aria-libc POSIX Regex Tests"));
    drop(println("=========================="));

    drop(test_constants());
    drop(test_compile_release());
    drop(test_is_match());
    drop(test_icase());
    drop(test_exec_groups());
    drop(test_no_match());
    drop(test_replace_first());
    drop(test_replace_all());
    drop(test_count());
    drop(test_error_reporting());
    drop(test_email_pattern());

    drop(println("=========================="));
    exit(0i32);
};
