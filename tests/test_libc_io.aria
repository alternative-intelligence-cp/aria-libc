// test_libc_io.aria — Tests for aria-libc I/O wrappers
//
// Compile:
//   ariac test_libc_io.aria -o test_libc_io -L../shim -laria_libc_io
//
// Run:
//   LD_LIBRARY_PATH=../shim ./test_libc_io

extern "aria_libc_io" {
    func:aria_libc_io_errno = int64();
    func:aria_libc_io_strerror = string(int64:errnum);

    func:aria_libc_io_open = int64(string:path, int64:flags, int64:mode);
    func:aria_libc_io_close = int64(int64:fd);
    func:aria_libc_io_write_string = int64(int64:fd, string:data);
    func:aria_libc_io_seek = int64(int64:fd, int64:offset, int64:whence);

    func:aria_libc_io_buf_create = int64(int64:capacity);
    func:aria_libc_io_buf_release = int64(int64:buf_id);
    func:aria_libc_io_buf_size = int64(int64:buf_id);
    func:aria_libc_io_buf_to_string = string(int64:buf_id);
    func:aria_libc_io_read = int64(int64:fd, int64:buf_id, int64:count);

    func:aria_libc_io_stat_size = int64(string:path);
    func:aria_libc_io_stat_is_dir = int64(string:path);
    func:aria_libc_io_stat_is_file = int64(string:path);
    func:aria_libc_io_stat_exists = int64(string:path);

    func:aria_libc_io_mkdir = int64(string:path, int64:mode);
    func:aria_libc_io_rmdir = int64(string:path);
    func:aria_libc_io_unlink = int64(string:path);
    func:aria_libc_io_rename = int64(string:old_path, string:new_path);
    func:aria_libc_io_opendir = int64(string:path);
    func:aria_libc_io_readdir_next = string(int64:dir_id);
    func:aria_libc_io_closedir = int64(int64:dir_id);

    func:aria_libc_io_read_file = string(string:path);
    func:aria_libc_io_write_file = int64(string:path, string:content);
    func:aria_libc_io_append_file = int64(string:path, string:content);

    func:aria_libc_io_O_RDONLY = int64();
    func:aria_libc_io_O_WRONLY = int64();
    func:aria_libc_io_O_CREAT = int64();
    func:aria_libc_io_O_TRUNC = int64();
    func:aria_libc_io_O_APPEND = int64();
}

int64:pass_count = 0i64;
int64:fail_count = 0i64;

func:assert_eq = NIL(int64:actual, int64:expected, string:msg) {
    if (actual == expected) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected: " + string_from_int(expected)));
        drop(print("    actual:   " + string_from_int(actual)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:assert_gt = NIL(int64:actual, int64:threshold, string:msg) {
    if (actual > threshold) {
        drop(print("  PASS: " + msg));
        pass_count = pass_count + 1i64;
    } else {
        drop(print("  FAIL: " + msg));
        drop(print("    expected > " + string_from_int(threshold)));
        drop(print("    actual:    " + string_from_int(actual)));
        fail_count = fail_count + 1i64;
    }
    pass(NIL);
};

func:failsafe = int32(tbb32:err) {
    drop(print("FAILSAFE triggered"));
    exit(1);
};

func:main = int32() {
    drop(print("=== aria-libc I/O Tests ==="));
    drop(print(""));

    string:test_dir = "/tmp/aria_libc_test";
    string:test_file = "/tmp/aria_libc_test/hello.txt";
    string:test_file2 = "/tmp/aria_libc_test/renamed.txt";

    // ── Test 1: mkdir + write file ──────────────────────────────
    drop(print("[Test 1] Write file"));
    drop(aria_libc_io_mkdir(test_dir, 493i64));

    int64:written = aria_libc_io_write_file(test_file, "Hello from aria-libc!\n");
    drop(assert_gt(written, 0i64, "write_file returns bytes written"));

    // ── Test 2: Stat exists ─────────────────────────────────────
    drop(print("[Test 2] Stat exists"));
    int64:file_exists = aria_libc_io_stat_exists(test_file);
    drop(assert_eq(file_exists, 1i64, "stat_exists finds the file"));

    int64:no_exists = aria_libc_io_stat_exists("/tmp/aria_libc_test/nope.txt");
    drop(assert_eq(no_exists, 0i64, "stat_exists returns 0 for missing file"));

    // ── Test 3: Stat size ───────────────────────────────────────
    drop(print("[Test 3] Stat size"));
    int64:sz = aria_libc_io_stat_size(test_file);
    drop(assert_eq(sz, 22i64, "stat_size returns correct size (22 bytes)"));

    // ── Test 4: Stat is_file / is_dir ───────────────────────────
    drop(print("[Test 4] Stat is_file / is_dir"));
    int64:is_f = aria_libc_io_stat_is_file(test_file);
    drop(assert_eq(is_f, 1i64, "stat_is_file returns 1 for file"));

    int64:is_d = aria_libc_io_stat_is_dir(test_dir);
    drop(assert_eq(is_d, 1i64, "stat_is_dir returns 1 for directory"));

    int64:not_d = aria_libc_io_stat_is_dir(test_file);
    drop(assert_eq(not_d, 0i64, "stat_is_dir returns 0 for file"));

    // ── Test 5: Read file ───────────────────────────────────────
    drop(print("[Test 5] Read file"));
    string:content = aria_libc_io_read_file(test_file);
    int64:content_len = string_length(content);
    drop(assert_eq(content_len, 22i64, "read_file returns correct content length"));

    // ── Test 6: Append file ─────────────────────────────────────
    drop(print("[Test 6] Append file"));
    int64:appended = aria_libc_io_append_file(test_file, "Second line\n");
    drop(assert_gt(appended, 0i64, "append_file returns bytes written"));

    int64:sz2 = aria_libc_io_stat_size(test_file);
    drop(assert_eq(sz2, 34i64, "File size after append is 34 bytes"));

    // ── Test 7: Low-level fd operations ─────────────────────────
    drop(print("[Test 7] Low-level fd open/write/close"));
    int64:wr_flags = aria_libc_io_O_WRONLY();
    int64:cr_flag = aria_libc_io_O_CREAT();
    int64:tr_flag = aria_libc_io_O_TRUNC();
    int64:combined = wr_flags + cr_flag + tr_flag;
    int64:fd = aria_libc_io_open("/tmp/aria_libc_test/fd_test.txt", combined, 420i64);
    drop(assert_gt(fd, 0i64, "open returns valid fd"));

    int64:w = aria_libc_io_write_string(fd, "Written via fd\n");
    drop(assert_eq(w, 15i64, "write_string returns correct byte count"));

    int64:cl = aria_libc_io_close(fd);
    drop(assert_eq(cl, 0i64, "close returns 0"));

    int64:fd_sz = aria_libc_io_stat_size("/tmp/aria_libc_test/fd_test.txt");
    drop(assert_eq(fd_sz, 15i64, "fd-written file has correct size"));

    // ── Test 8: Buffer-based read ───────────────────────────────
    drop(print("[Test 8] Buffer-based read"));
    int64:buf = aria_libc_io_buf_create(4096i64);
    drop(assert_gt(buf, 0i64 - 1i64, "buf_create returns valid id"));

    int64:rd_flag = aria_libc_io_O_RDONLY();
    int64:rfd = aria_libc_io_open(test_file, rd_flag, 0i64);
    drop(assert_gt(rfd, 0i64, "open for read returns valid fd"));

    int64:n = aria_libc_io_read(rfd, buf, 4096i64);
    drop(assert_eq(n, 34i64, "read returns correct bytes (34 after append)"));

    int64:bsz = aria_libc_io_buf_size(buf);
    drop(assert_eq(bsz, 34i64, "buf_size matches bytes read"));

    string:buf_content = aria_libc_io_buf_to_string(buf);
    int64:buf_len = string_length(buf_content);
    drop(assert_eq(buf_len, 34i64, "buf_to_string has correct length"));

    int64:br = aria_libc_io_buf_release(buf);
    drop(assert_eq(br, 0i64, "buf_release returns 0"));

    int64:rc = aria_libc_io_close(rfd);
    drop(assert_eq(rc, 0i64, "close read fd returns 0"));

    // ── Test 9: Directory listing ───────────────────────────────
    drop(print("[Test 9] Directory listing"));
    int64:dir_id = aria_libc_io_opendir(test_dir);
    drop(assert_gt(dir_id, 0i64 - 1i64, "opendir returns valid id"));

    int64:entry_count = 0i64;
    string:entry1 = aria_libc_io_readdir_next(dir_id);
    int64:e1_len = string_length(entry1);
    if (e1_len > 0i64) {
        entry_count = entry_count + 1i64;
    }
    string:entry2 = aria_libc_io_readdir_next(dir_id);
    int64:e2_len = string_length(entry2);
    if (e2_len > 0i64) {
        entry_count = entry_count + 1i64;
    }
    string:entry3 = aria_libc_io_readdir_next(dir_id);
    int64:e3_len = string_length(entry3);
    if (e3_len > 0i64) {
        entry_count = entry_count + 1i64;
    }
    string:entry4 = aria_libc_io_readdir_next(dir_id);
    int64:e4_len = string_length(entry4);
    if (e4_len > 0i64) {
        entry_count = entry_count + 1i64;
    }
    drop(assert_gt(entry_count, 2i64, "readdir found >2 entries (., .., and files)"));

    int64:cd = aria_libc_io_closedir(dir_id);
    drop(assert_eq(cd, 0i64, "closedir returns 0"));

    // ── Test 10: Rename ─────────────────────────────────────────
    drop(print("[Test 10] Rename"));
    int64:ren = aria_libc_io_rename("/tmp/aria_libc_test/fd_test.txt", test_file2);
    drop(assert_eq(ren, 0i64, "rename returns 0"));

    int64:old_gone = aria_libc_io_stat_exists("/tmp/aria_libc_test/fd_test.txt");
    drop(assert_eq(old_gone, 0i64, "old file gone after rename"));

    int64:new_there = aria_libc_io_stat_exists(test_file2);
    drop(assert_eq(new_there, 1i64, "new file exists after rename"));

    // ── Test 11: Unlink ─────────────────────────────────────────
    drop(print("[Test 11] Unlink"));
    int64:ul1 = aria_libc_io_unlink(test_file);
    drop(assert_eq(ul1, 0i64, "unlink hello.txt returns 0"));

    int64:ul2 = aria_libc_io_unlink(test_file2);
    drop(assert_eq(ul2, 0i64, "unlink renamed.txt returns 0"));

    // ── Test 12: Rmdir ──────────────────────────────────────────
    drop(print("[Test 12] Rmdir"));
    int64:rd2 = aria_libc_io_rmdir(test_dir);
    drop(assert_eq(rd2, 0i64, "rmdir returns 0"));

    int64:dir_gone = aria_libc_io_stat_exists(test_dir);
    drop(assert_eq(dir_gone, 0i64, "directory gone after rmdir"));

    // ── Test 13: Errno ──────────────────────────────────────────
    drop(print("[Test 13] Errno on failure"));
    int64:rdonly = aria_libc_io_O_RDONLY();
    int64:bad_fd = aria_libc_io_open("/tmp/aria_libc_test_nonexistent_file.txt", rdonly, 0i64);
    drop(assert_eq(bad_fd, 0i64 - 1i64, "open nonexistent file returns -1"));

    int64:err = aria_libc_io_errno();
    drop(assert_gt(err, 0i64, "errno is set after failed open"));

    string:err_msg = aria_libc_io_strerror(err);
    int64:err_len = string_length(err_msg);
    drop(assert_gt(err_len, 0i64, "strerror returns non-empty message"));

    // ── Summary ─────────────────────────────────────────────────
    drop(print(""));
    drop(print("=== Results ==="));
    drop(print("Passed: " + string_from_int(pass_count)));
    drop(print("Failed: " + string_from_int(fail_count)));

    int64:total = pass_count + fail_count;
    drop(print("Total:  " + string_from_int(total)));

    if (fail_count == 0i64) {
        drop(print("ALL TESTS PASSED!"));
    } else {
        drop(print("SOME TESTS FAILED"));
    }

    exit(0);
};
