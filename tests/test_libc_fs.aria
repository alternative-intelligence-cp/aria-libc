// Main
// ══════════════════════════════════════════════════════════════════

func:failsafe = int32(tbb32:err) {
    drop(println("Failsafe triggered"));
    exit(1i32);
};

func:main = int32() {
    drop(println("aria-libc Filesystem Extras Tests"));
    drop(println("================================="));

    drop(test_access_constants());
    drop(test_permission_constants());
    drop(test_fnmatch_constants());
    drop(test_access());
    drop(test_chmod());
    drop(test_symlink());
    drop(test_hardlink());
    drop(test_truncate());
    drop(test_realpath());
    drop(test_mkdtemp());
    drop(test_mkstemp());
    drop(test_fnmatch());
    drop(test_glob());
    drop(test_error());

    drop(println("================================="));
    exit(0i32);
};
