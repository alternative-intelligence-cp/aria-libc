};

pub func:libc_net_inet_ntoa = string(int64:ip) {
    string:addr = aria_libc_net_inet_ntoa(ip);
    pass(addr);
};

pub func:libc_net_htons = int64(int64:val) {
    int64:r = aria_libc_net_htons(val);
