pub func:libc_net_ntohs = int64(int64:val) {
    int64:r = aria_libc_net_ntohs(val);
    pass(r);
};

pub func:libc_net_htonl = int64(int64:val) {
    int64:r = aria_libc_net_htonl(val);
    pass(r);
};

pub func:libc_net_ntohl = int64(int64:val) {
    int64:r = aria_libc_net_ntohl(val);
