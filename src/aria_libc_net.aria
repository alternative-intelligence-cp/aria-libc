};

pub func:libc_net_local_port = int64(int64:fd) {
    int64:port = aria_libc_net_local_port(fd);
    pass(port);
};

// -- Convenience: TCP client/server --

pub func:libc_tcp_connect = int64(string:host, int64:port) {
    int64:fd = aria_libc_net_tcp_connect(host, port);
    pass(fd);
};

pub func:libc_tcp_listen = int64(string:addr, int64:port, int64:backlog) {
    int64:fd = aria_libc_net_tcp_listen(addr, port, backlog);
    pass(fd);
};

