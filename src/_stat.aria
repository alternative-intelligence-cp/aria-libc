// ── Convenience: type checks and existence ──────────────────────────

pub func:libc_stat_is_dir = int64(string:path) {
    int64:buf = _stat_path(path) ?! 0i64;
    if (buf == 0i64) { pass(0i64); }
    int64:mode = aria_libc_mem_read_int32(buf, STAT_OFF_MODE);
    drop(sys(MUNMAP, buf, STAT_BUF_SIZE));
    uint64:umode = @cast<uint64>(mode);
    uint64:ufmt = @cast<uint64>(S_IFMT);
    uint64:ftype = umode & ufmt;
    uint64:udir = @cast<uint64>(S_IFDIR);
    if (ftype == udir) {
        pass(1i64);
    }
    pass(0i64);
};

pub func:libc_stat_is_file = int64(string:path) {
    int64:buf = _stat_path(path) ?! 0i64;
    if (buf == 0i64) { pass(0i64); }
    int64:mode = aria_libc_mem_read_int32(buf, STAT_OFF_MODE);
    drop(sys(MUNMAP, buf, STAT_BUF_SIZE));
    uint64:umode = @cast<uint64>(mode);
    uint64:ufmt = @cast<uint64>(S_IFMT);
    uint64:ftype = umode & ufmt;
    uint64:ureg = @cast<uint64>(S_IFREG);
    if (ftype == ureg) {
        pass(1i64);
    }
    pass(0i64);
};

pub func:libc_stat_is_symlink = int64(string:path) {
    // Use AT_SYMLINK_NOFOLLOW to detect symlinks themselves
    Result<int64>:buf_r = sys(MMAP, 0i64, STAT_BUF_SIZE, 3i64, 34i64, -1i64, 0i64);
    int64:buf = buf_r ? 0i64;
    if (buf < 1i64) { pass(0i64); }

    // AT_FDCWD inline (compiler bug: imported negatives are zeroed)
    int64:fdcwd = 0i64 - 100i64;
    Result<int64>:r = sys(NEWFSTATAT, fdcwd, path, buf, AT_SYMLINK_NOFOLLOW);
    int64:ret = r ? -1i64;
    if (ret < 0i64) {
        drop(sys(MUNMAP, buf, STAT_BUF_SIZE));
        pass(0i64);
    }

    int64:mode = aria_libc_mem_read_int32(buf, STAT_OFF_MODE);
    drop(sys(MUNMAP, buf, STAT_BUF_SIZE));
    uint64:umode = @cast<uint64>(mode);
    uint64:ufmt = @cast<uint64>(S_IFMT);
    uint64:ftype = umode & ufmt;
    uint64:ulnk = @cast<uint64>(S_IFLNK);
    if (ftype == ulnk) {
        pass(1i64);
    }
    pass(0i64);
};

pub func:libc_stat_exists = int64(string:path) {
    int64:buf = _stat_path(path) ?! 0i64;
    if (buf == 0i64) { pass(0i64); }
    drop(sys(MUNMAP, buf, STAT_BUF_SIZE));
    pass(1i64);
};

// ── Bulk: get multiple fields in one syscall ────────────────────────
// For callers who need multiple fields, this avoids repeated mmap/syscall overhead.
// Returns a fixed-width "struct" via multiple out-values encoded in a single
// stat call. The caller can then read individual fields.

// Returns the raw buffer pointer. Caller MUST call libc_stat_buf_release(buf) when done.
pub func:libc_stat_buf = int64(string:path) {
    int64:buf = _stat_path(path) ?! 0i64;
    pass(buf);
};

pub func:libc_stat_buf_release = int64(int64:buf) {
    if (buf == 0i64) { pass(0i64); }
    Result<int64>:r = sys(MUNMAP, buf, STAT_BUF_SIZE);
    int64:ret = r ? -1i64;
    pass(ret);
};

pub func:libc_stat_buf_size = int64(int64:buf) {
    pass(aria_libc_mem_read_int64(buf, STAT_OFF_SIZE));
};

pub func:libc_stat_buf_mode = int64(int64:buf) {
    pass(aria_libc_mem_read_int32(buf, STAT_OFF_MODE));
};

pub func:libc_stat_buf_mtime = int64(int64:buf) {
    pass(aria_libc_mem_read_int64(buf, STAT_OFF_MTIME));
};

pub func:libc_stat_buf_uid = int64(int64:buf) {
    pass(aria_libc_mem_read_int32(buf, STAT_OFF_UID));
};

pub func:libc_stat_buf_gid = int64(int64:buf) {
    pass(aria_libc_mem_read_int32(buf, STAT_OFF_GID));
};

pub func:libc_stat_buf_ino = int64(int64:buf) {
    pass(aria_libc_mem_read_int64(buf, STAT_OFF_INO));
};
