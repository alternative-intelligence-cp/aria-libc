// aria_libc_posix.aria — Extended POSIX wrappers: signals, fork/exec, pipe, mmap
//
// Usage:
//   use "../src/aria_libc_posix.aria".*;
//
// Link:
//   -L../shim -laria_libc_posix

extern "aria_libc_posix" {
    // Error state
    func:aria_libc_posix_errno = int64();
    func:aria_libc_posix_strerror = string(int64:errnum);

    // ── Signal constants ──
    func:aria_libc_posix_SIGHUP = int64();
    func:aria_libc_posix_SIGINT = int64();
    func:aria_libc_posix_SIGQUIT = int64();
    func:aria_libc_posix_SIGILL = int64();
    func:aria_libc_posix_SIGABRT = int64();
    func:aria_libc_posix_SIGFPE = int64();
    func:aria_libc_posix_SIGKILL = int64();
    func:aria_libc_posix_SIGSEGV = int64();
    func:aria_libc_posix_SIGPIPE = int64();
    func:aria_libc_posix_SIGALRM = int64();
    func:aria_libc_posix_SIGTERM = int64();
    func:aria_libc_posix_SIGUSR1 = int64();
    func:aria_libc_posix_SIGUSR2 = int64();
    func:aria_libc_posix_SIGCHLD = int64();
    func:aria_libc_posix_SIGCONT = int64();
    func:aria_libc_posix_SIGSTOP = int64();
    func:aria_libc_posix_SIGTSTP = int64();

    // ── Signal handling ──
    func:aria_libc_posix_signal_trap = int64(int64:signum);
    func:aria_libc_posix_signal_check = int64(int64:signum);
    func:aria_libc_posix_signal_reset = int64(int64:signum);
    func:aria_libc_posix_signal_ignore = int64(int64:signum);
    func:aria_libc_posix_raise = int64(int64:signum);
    func:aria_libc_posix_kill = int64(int64:pid, int64:signum);

    // ── Fork / exec / wait ──
    func:aria_libc_posix_fork = int64();
    func:aria_libc_posix_waitpid = int64(int64:pid, int64:flags);
    func:aria_libc_posix_WNOHANG = int64();
    func:aria_libc_posix_wait_exited = int64();
    func:aria_libc_posix_wait_status = int64();
    func:aria_libc_posix_wait_signaled = int64();
    func:aria_libc_posix_wait_termsig = int64();
    func:aria_libc_posix_exec_shell = int64(string:cmd);
    func:aria_libc_posix_spawn = int64(string:cmd);
    func:aria_libc_posix_spawn_bg = int64(string:cmd);
    func:aria_libc_posix_exit_now = void(int64:code);

    // ── Pipe + dup ──
    func:aria_libc_posix_pipe_create = int64();
    func:aria_libc_posix_pipe_read_fd = int64();
    func:aria_libc_posix_pipe_write_fd = int64();
    func:aria_libc_posix_dup = int64(int64:oldfd);
    func:aria_libc_posix_dup2 = int64(int64:oldfd, int64:newfd);
    func:aria_libc_posix_fd_write_string = int64(int64:fd, string:data);
    func:aria_libc_posix_fd_read_string = string(int64:fd, int64:max_bytes);
    func:aria_libc_posix_fd_close = int64(int64:fd);

    // ── mmap constants ──
    func:aria_libc_posix_PROT_NONE = int64();
    func:aria_libc_posix_PROT_READ = int64();
    func:aria_libc_posix_PROT_WRITE = int64();
    func:aria_libc_posix_PROT_EXEC = int64();
    func:aria_libc_posix_MAP_SHARED = int64();
    func:aria_libc_posix_MAP_PRIVATE = int64();
    func:aria_libc_posix_MAP_ANONYMOUS = int64();
    func:aria_libc_posix_MAP_FIXED = int64();
    func:aria_libc_posix_MS_ASYNC = int64();
    func:aria_libc_posix_MS_SYNC = int64();
    func:aria_libc_posix_MS_INVALIDATE = int64();

    // ── mmap operations ──
    func:aria_libc_posix_mmap = int64(int64:length, int64:prot, int64:flags, int64:fd, int64:offset);
    func:aria_libc_posix_munmap = int64(int64:handle);
    func:aria_libc_posix_mprotect = int64(int64:handle, int64:prot);
    func:aria_libc_posix_msync = int64(int64:handle, int64:flags);
    func:aria_libc_posix_mmap_length = int64(int64:handle);
    func:aria_libc_posix_mmap_read_byte = int64(int64:handle, int64:offset);
    func:aria_libc_posix_mmap_write_byte = int64(int64:handle, int64:offset, int64:value);
    func:aria_libc_posix_mmap_read_int64 = int64(int64:handle, int64:offset);
    func:aria_libc_posix_mmap_write_int64 = int64(int64:handle, int64:offset, int64:value);
    func:aria_libc_posix_mmap_to_string = string(int64:handle, int64:offset, int64:length);
    func:aria_libc_posix_mmap_from_string = int64(int64:handle, int64:offset, string:data);
}

