pub func:libc_posix_mmap = int64(int64:length, int64:prot, int64:flags, int64:fd, int64:offset) {
    pass(aria_libc_posix_mmap(length, prot, flags, fd, offset));
};
pub func:libc_posix_munmap = int64(int64:handle) { pass(aria_libc_posix_munmap(handle)); };
pub func:libc_posix_mprotect = int64(int64:handle, int64:prot) { pass(aria_libc_posix_mprotect(handle, prot)); };
