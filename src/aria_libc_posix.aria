pub func:libc_posix_waitpid = int64(int64:pid, int64:flags) { pass(aria_libc_posix_waitpid(pid, flags)); };
pub func:libc_posix_WNOHANG = int64() { pass(aria_libc_posix_WNOHANG()); };
